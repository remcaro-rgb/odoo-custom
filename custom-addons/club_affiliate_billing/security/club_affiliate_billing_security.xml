<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ── Security Groups ──────────────────────────────────────── -->

        <record id="group_billing_staff" model="res.groups">
            <field name="name">Club Billing Staff</field>
            <field name="category_id" ref="base.module_category_hidden"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- ── Record Rules ─────────────────────────────────────────── -->

        <!-- Portal: affiliate sees own billing invoices -->
        <record id="rule_billing_invoice_portal_own" model="ir.rule">
            <field name="name">Billing Invoice: portal sees own records</field>
            <field name="model_id" ref="model_club_affiliate_billing_invoice"/>
            <field name="domain_force">[('affiliate_id.partner_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('club_core.group_club_member'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Portal: affiliate sees own billing lines -->
        <record id="rule_billing_line_portal_own" model="ir.rule">
            <field name="name">Billing Line: portal sees own records</field>
            <field name="model_id" ref="model_club_affiliate_billing_line"/>
            <field name="domain_force">[('billing_invoice_id.affiliate_id.partner_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('club_core.group_club_member'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

    </data>
</odoo>
