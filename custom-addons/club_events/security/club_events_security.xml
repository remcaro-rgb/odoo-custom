<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ── Security Groups ──────────────────────────────────────── -->

        <record id="group_events_staff" model="res.groups">
            <field name="name">Events Staff</field>
            <field name="category_id" ref="base.module_category_hidden"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- ── Record Rules ─────────────────────────────────────────── -->

        <!-- Club members (portal) can see all events -->
        <record id="rule_event_club_member_all" model="ir.rule">
            <field name="name">Event: club members see all events</field>
            <field name="model_id" ref="event.model_event_event"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('club_core.group_club_member'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Base portal users (non-members) can only see public events -->
        <record id="rule_event_portal_public_only" model="ir.rule">
            <field name="name">Event: portal sees only public events</field>
            <field name="model_id" ref="event.model_event_event"/>
            <field name="domain_force">[('member_only', '=', False)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Portal users see only their own registrations -->
        <record id="rule_registration_portal_own" model="ir.rule">
            <field name="name">Registration: portal sees own registrations</field>
            <field name="model_id" ref="event.model_event_registration"/>
            <field name="domain_force">[('partner_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

    </data>
</odoo>
