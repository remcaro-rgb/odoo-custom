<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view -->
    <record id="view_club_golf_caddie_list" model="ir.ui.view">
        <field name="name">club.golf.caddie.list</field>
        <field name="model">club.golf.caddie</field>
        <field name="arch" type="xml">
            <list>
                <field name="partner_id"/>
                <field name="employee_number"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_club_golf_caddie_form" model="ir.ui.view">
        <field name="name">club.golf.caddie.form</field>
        <field name="model">club.golf.caddie</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="partner_id"/>
                        <h1><field name="partner_id"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_number"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Availability" name="availability">
                            <field name="availability_ids">
                                <list editable="bottom">
                                    <field name="day_of_week"/>
                                    <field name="time_from" widget="float_time"/>
                                    <field name="time_to" widget="float_time"/>
                                </list>
                            </field>
                        </page>
                        <page string="Tee Times" name="tee_times">
                            <field name="tee_time_ids">
                                <list>
                                    <field name="date"/>
                                    <field name="time_slot" widget="float_time"/>
                                    <field name="course_id"/>
                                    <field name="status" widget="badge"
                                        decoration-success="status == 'available'"
                                        decoration-info="status == 'booked'"
                                        decoration-muted="status == 'completed'"
                                        decoration-danger="status == 'cancelled'"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_club_golf_caddie_search" model="ir.ui.view">
        <field name="name">club.golf.caddie.search</field>
        <field name="model">club.golf.caddie</field>
        <field name="arch" type="xml">
            <search>
                <field name="partner_id"/>
                <field name="employee_number"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_club_golf_caddie" model="ir.actions.act_window">
        <field name="name">Caddies</field>
        <field name="res_model">club.golf.caddie</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_club_golf_caddie_search"/>
        <field name="path">golf-caddies</field>
    </record>

</odoo>
