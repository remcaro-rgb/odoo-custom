<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view -->
    <record id="view_club_access_checkpoint_list" model="ir.ui.view">
        <field name="name">club.access.checkpoint.list</field>
        <field name="model">club.access.checkpoint</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="location"/>
                <field name="checkpoint_type"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_club_access_checkpoint_form" model="ir.ui.view">
        <field name="name">club.access.checkpoint.form</field>
        <field name="model">club.access.checkpoint</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="checkpoint_type"/>
                            <field name="location"/>
                        </group>
                        <group>
                            <field name="active"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Additional notes..."/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_club_access_checkpoint_search" model="ir.ui.view">
        <field name="name">club.access.checkpoint.search</field>
        <field name="model">club.access.checkpoint</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="location"/>
                <filter name="active" string="Active" domain="[('active', '=', True)]"/>
                <group expand="0" string="Group By">
                    <filter name="group_type" string="Type"
                        context="{'group_by': 'checkpoint_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_club_access_checkpoint" model="ir.actions.act_window">
        <field name="name">Checkpoints</field>
        <field name="res_model">club.access.checkpoint</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_club_access_checkpoint_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="path">club-access-checkpoints</field>
    </record>

</odoo>
