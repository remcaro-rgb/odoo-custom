<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════════
         GUARD INTERFACE — Form view (optimized for quick guard use)
         ══════════════════════════════════════════════════════════════ -->

    <record id="view_club_access_entry_form" model="ir.ui.view">
        <field name="name">club.access.entry.form</field>
        <field name="model">club.access.entry</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_lookup" type="object" string="Search"
                        class="btn-primary"
                        invisible="access_status != 'pending'"/>
                    <button name="action_grant" type="object" string="Grant Access"
                        class="btn-success"
                        invisible="access_status != 'pending'"
                        confirm="Grant access manually without lookup?"/>
                    <button name="action_deny_wizard" type="object" string="Deny Access"
                        class="btn-danger"
                        invisible="access_status != 'pending'"/>
                    <button name="action_exit" type="object" string="Register Exit"
                        class="btn-warning"
                        invisible="access_status != 'granted'"/>
                    <field name="access_status" widget="statusbar"
                        statusbar_visible="pending,granted,exited"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <widget name="web_ribbon" title="Denied" bg_color="text-bg-danger"
                        invisible="access_status != 'denied'"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>

                    <!-- SCAN/INPUT SECTION -->
                    <group string="Identification">
                        <group>
                            <field name="checkpoint_id"/>
                            <field name="identification_method"/>
                            <field name="identification_value"
                                placeholder="Scan or type identifier..."/>
                        </group>
                        <group>
                            <field name="entry_datetime"/>
                            <field name="exit_datetime" readonly="1"/>
                            <field name="authorized_by"/>
                            <field name="duration_minutes" readonly="1"
                                invisible="not exit_datetime"/>
                        </group>
                    </group>

                    <!-- RESULT SECTION — shows after lookup -->
                    <group string="Person Identified" invisible="not person_type">
                        <group>
                            <field name="person_type" readonly="1"/>
                            <field name="person_name" readonly="1"/>
                            <field name="denial_reason"
                                invisible="access_status != 'denied'" readonly="1"/>
                        </group>
                        <group>
                            <field name="affiliate_id"
                                invisible="person_type not in ('affiliate', 'family_member')"
                                readonly="1"/>
                            <field name="employee_id"
                                invisible="person_type != 'affiliate_employee'"
                                readonly="1"/>
                            <field name="guest_id"
                                invisible="person_type != 'guest'"
                                readonly="1"/>
                            <field name="guest_visit_id"
                                invisible="person_type != 'guest'"
                                readonly="1"/>
                            <field name="event_registration_id"
                                invisible="person_type != 'event_attendee'"
                                readonly="1"/>
                            <field name="tournament_participant_id"
                                invisible="person_type != 'tournament_participant'"
                                readonly="1"/>
                            <field name="supplier_staff_id"
                                invisible="person_type != 'supplier_staff'"
                                readonly="1"/>
                            <field name="vehicle_id"
                                invisible="not vehicle_id"
                                readonly="1"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Additional notes..."/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════
         List view — Access log
         ══════════════════════════════════════════════════════════════ -->

    <record id="view_club_access_entry_list" model="ir.ui.view">
        <field name="name">club.access.entry.list</field>
        <field name="model">club.access.entry</field>
        <field name="arch" type="xml">
            <list decoration-danger="access_status == 'denied'"
                  decoration-success="access_status == 'granted'"
                  decoration-muted="access_status == 'exited'">
                <field name="name"/>
                <field name="entry_datetime"/>
                <field name="person_name"/>
                <field name="person_type" widget="badge"
                    decoration-info="person_type in ('affiliate', 'family_member')"
                    decoration-success="person_type == 'affiliate_employee'"
                    decoration-warning="person_type == 'guest'"
                    decoration-danger="person_type == 'supplier_staff'"/>
                <field name="checkpoint_id"/>
                <field name="identification_method"/>
                <field name="access_status" widget="badge"
                    decoration-info="access_status == 'pending'"
                    decoration-success="access_status == 'granted'"
                    decoration-danger="access_status == 'denied'"
                    decoration-warning="access_status == 'exited'"/>
                <field name="exit_datetime" optional="hide"/>
                <field name="duration_minutes" optional="hide"/>
                <field name="authorized_by" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════
         Kanban view — Active entries
         ══════════════════════════════════════════════════════════════ -->

    <record id="view_club_access_entry_kanban" model="ir.ui.view">
        <field name="name">club.access.entry.kanban</field>
        <field name="model">club.access.entry</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="person_name"/>
                <field name="person_type"/>
                <field name="checkpoint_id"/>
                <field name="entry_datetime"/>
                <field name="access_status"/>
                <field name="is_active_entry"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <strong><field name="person_name"/></strong>
                            </div>
                            <div class="o_kanban_record_body">
                                <span class="text-muted"><field name="name"/></span><br/>
                                <field name="person_type" widget="badge"
                                    decoration-info="person_type in ('affiliate', 'family_member')"
                                    decoration-success="person_type == 'affiliate_employee'"
                                    decoration-warning="person_type == 'guest'"/>
                                <br/>
                                <span>Checkpoint: <field name="checkpoint_id"/></span><br/>
                                <span class="text-muted">
                                    Entry: <field name="entry_datetime"/>
                                </span>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <field name="access_status" widget="badge"
                                    decoration-success="access_status == 'granted'"
                                    decoration-danger="access_status == 'denied'"
                                    decoration-warning="access_status == 'exited'"
                                    decoration-info="access_status == 'pending'"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════
         Search view
         ══════════════════════════════════════════════════════════════ -->

    <record id="view_club_access_entry_search" model="ir.ui.view">
        <field name="name">club.access.entry.search</field>
        <field name="model">club.access.entry</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="person_name"/>
                <field name="identification_value"/>
                <field name="checkpoint_id"/>
                <field name="affiliate_id"/>
                <field name="employee_id"/>
                <field name="guest_id"/>
                <field name="supplier_staff_id"/>
                <separator/>
                <filter name="today" string="Today"
                    domain="[('entry_datetime', '&gt;=',
                        (context_today()).strftime('%Y-%m-%d 00:00:00')),
                        ('entry_datetime', '&lt;',
                        (context_today() + datetime.timedelta(days=1)).strftime('%Y-%m-%d 00:00:00'))]"/>
                <filter name="active_entries" string="Active Entries"
                    domain="[('is_active_entry', '=', True)]"/>
                <separator/>
                <filter name="granted" string="Granted"
                    domain="[('access_status', '=', 'granted')]"/>
                <filter name="denied" string="Denied"
                    domain="[('access_status', '=', 'denied')]"/>
                <filter name="pending" string="Pending"
                    domain="[('access_status', '=', 'pending')]"/>
                <filter name="exited" string="Exited"
                    domain="[('access_status', '=', 'exited')]"/>
                <separator/>
                <filter name="type_affiliate" string="Affiliates"
                    domain="[('person_type', 'in', ('affiliate', 'family_member'))]"/>
                <filter name="type_employee" string="Employees"
                    domain="[('person_type', '=', 'affiliate_employee')]"/>
                <filter name="type_guest" string="Guests"
                    domain="[('person_type', '=', 'guest')]"/>
                <filter name="type_event" string="Event Attendees"
                    domain="[('person_type', '=', 'event_attendee')]"/>
                <filter name="type_tournament" string="Tournament Participants"
                    domain="[('person_type', '=', 'tournament_participant')]"/>
                <filter name="type_supplier" string="Supplier Staff"
                    domain="[('person_type', '=', 'supplier_staff')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_person_type" string="Person Type"
                        context="{'group_by': 'person_type'}"/>
                    <filter name="group_checkpoint" string="Checkpoint"
                        context="{'group_by': 'checkpoint_id'}"/>
                    <filter name="group_status" string="Access Status"
                        context="{'group_by': 'access_status'}"/>
                    <filter name="group_date" string="Entry Date"
                        context="{'group_by': 'entry_datetime:day'}"/>
                    <filter name="group_method" string="Identification Method"
                        context="{'group_by': 'identification_method'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════
         Actions
         ══════════════════════════════════════════════════════════════ -->

    <!-- New Entry — opens form directly for guard quick-access -->
    <record id="action_club_access_entry_new" model="ir.actions.act_window">
        <field name="name">New Entry</field>
        <field name="res_model">club.access.entry</field>
        <field name="view_mode">form</field>
        <field name="path">club-access-new-entry</field>
    </record>

    <!-- Access Log — all entries -->
    <record id="action_club_access_entry_log" model="ir.actions.act_window">
        <field name="name">Access Log</field>
        <field name="res_model">club.access.entry</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_club_access_entry_search"/>
        <field name="context">{'search_default_today': 1}</field>
        <field name="path">club-access-log</field>
    </record>

    <!-- Active Entries — currently inside the club -->
    <record id="action_club_access_entry_active" model="ir.actions.act_window">
        <field name="name">Active Entries</field>
        <field name="res_model">club.access.entry</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_club_access_entry_search"/>
        <field name="domain">[('is_active_entry', '=', True)]</field>
        <field name="path">club-access-active</field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════
         Deny Access Wizard
         ══════════════════════════════════════════════════════════════ -->

    <record id="view_club_access_deny_wizard_form" model="ir.ui.view">
        <field name="name">club.access.deny.wizard.form</field>
        <field name="model">club.access.deny.wizard</field>
        <field name="arch" type="xml">
            <form string="Deny Access">
                <group>
                    <field name="entry_id" invisible="1"/>
                    <field name="reason" placeholder="Enter denial reason..."/>
                </group>
                <footer>
                    <button name="action_confirm" type="object" string="Confirm Denial"
                        class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
