<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_club_access_lookup_wizard_form" model="ir.ui.view">
        <field name="name">club.access.lookup.wizard.form</field>
        <field name="model">club.access.lookup.wizard</field>
        <field name="arch" type="xml">
            <form string="Lookup Results">
                <group>
                    <field name="entry_id" invisible="1"/>
                    <field name="search_term" readonly="1"/>
                </group>
                <field name="result_ids" nolabel="1">
                    <list>
                        <field name="photo" widget="image" options="{'size': [40, 40]}"/>
                        <field name="display_name"/>
                        <field name="person_type" widget="badge"/>
                        <field name="identification"/>
                        <button name="action_select" type="object"
                            string="Select" class="btn-primary btn-sm"/>
                    </list>
                </field>
                <footer>
                    <button name="action_done" type="object" string="Close"
                        class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
