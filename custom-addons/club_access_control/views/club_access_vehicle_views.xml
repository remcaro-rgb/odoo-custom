<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view -->
    <record id="view_club_access_vehicle_list" model="ir.ui.view">
        <field name="name">club.access.vehicle.list</field>
        <field name="model">club.access.vehicle</field>
        <field name="arch" type="xml">
            <list>
                <field name="plate_number"/>
                <field name="affiliate_id"/>
                <field name="vehicle_type"/>
                <field name="brand"/>
                <field name="model"/>
                <field name="color"/>
                <field name="year"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_club_access_vehicle_form" model="ir.ui.view">
        <field name="name">club.access.vehicle.form</field>
        <field name="model">club.access.vehicle</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="plate_number"/>
                        <h1><field name="plate_number"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="affiliate_id"/>
                            <field name="vehicle_type"/>
                            <field name="brand"/>
                            <field name="model"/>
                        </group>
                        <group>
                            <field name="color"/>
                            <field name="year"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Additional notes..."/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_club_access_vehicle_search" model="ir.ui.view">
        <field name="name">club.access.vehicle.search</field>
        <field name="model">club.access.vehicle</field>
        <field name="arch" type="xml">
            <search>
                <field name="plate_number"/>
                <field name="affiliate_id"/>
                <field name="brand"/>
                <filter name="active" string="Active" domain="[('active', '=', True)]"/>
                <filter name="archived" string="Archived" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter name="group_affiliate" string="Affiliate"
                        context="{'group_by': 'affiliate_id'}"/>
                    <filter name="group_type" string="Vehicle Type"
                        context="{'group_by': 'vehicle_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_club_access_vehicle" model="ir.actions.act_window">
        <field name="name">Vehicles</field>
        <field name="res_model">club.access.vehicle</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_club_access_vehicle_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="path">club-access-vehicles</field>
    </record>

</odoo>
