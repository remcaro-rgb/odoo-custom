<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="restaurant_board_view" model="ir.ui.view">
        <field name="name">Tablero de Restaurante</field>
        <field name="model">board.board</field>
        <field name="arch" type="xml">
            <form string="Tablero de Restaurante">
                <board style="2-1">
                    <column>
                        <action name="%(co_dashboards.action_dashboard_recipe_cost)d"
                                string="Análisis de Costos por Receta"/>
                        <action name="%(co_dashboards.action_dashboard_food_cost_pct)d"
                                string="Food Cost % por Categoría"/>
                        <action name="%(co_dashboards.action_dashboard_production_variance)d"
                                string="Varianza de Producción"/>
                    </column>
                    <column>
                        <action name="%(co_dashboards.action_dashboard_production_state)d"
                                string="Producción por Estado"/>
                        <action name="%(co_dashboards.action_dashboard_waste)d"
                                string="Desperdicios por Tipo"/>
                    </column>
                </board>
            </form>
        </field>
    </record>

    <record id="action_restaurant_board" model="ir.actions.act_window">
        <field name="name">Tablero de Restaurante</field>
        <field name="res_model">board.board</field>
        <field name="view_mode">form</field>
        <field name="context">{'disable_toolbar': True}</field>
        <field name="usage">menu</field>
        <field name="view_id" ref="restaurant_board_view"/>
    </record>
</odoo>
