<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="club_board_view" model="ir.ui.view">
        <field name="name">Tablero del Club</field>
        <field name="model">board.board</field>
        <field name="arch" type="xml">
            <form string="Tablero del Club">
                <board style="2-1">
                    <column>
                        <action name="%(co_dashboards.action_dashboard_affiliates_type)d"
                                string="Afiliados por Tipo"/>
                        <action name="%(co_dashboards.action_dashboard_memberships_status)d"
                                string="Membresías por Estado"/>
                        <action name="%(co_dashboards.action_dashboard_access_person)d"
                                string="Accesos por Tipo de Persona"/>
                        <action name="%(co_dashboards.action_dashboard_pqr_status)d"
                                string="PQR por Estado"/>
                    </column>
                    <column>
                        <action name="%(co_dashboards.action_dashboard_access_checkpoint)d"
                                string="Accesos por Punto de Control"/>
                        <action name="%(co_dashboards.action_dashboard_guest_visits)d"
                                string="Visitas de Invitados por Área"/>
                        <action name="%(co_dashboards.action_dashboard_affiliate_billing)d"
                                string="Facturación de Afiliados"/>
                    </column>
                </board>
            </form>
        </field>
    </record>

    <record id="action_club_board" model="ir.actions.act_window">
        <field name="name">Tablero del Club</field>
        <field name="res_model">board.board</field>
        <field name="view_mode">form</field>
        <field name="context">{'disable_toolbar': True}</field>
        <field name="usage">menu</field>
        <field name="view_id" ref="club_board_view"/>
    </record>
</odoo>
