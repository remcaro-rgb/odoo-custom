<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- 1. AFILIADOS POR TIPO                                         -->
    <!-- ============================================================ -->
    <record id="dashboard_affiliates_type_graph" model="ir.ui.view">
        <field name="name">dashboard.affiliates.type.graph</field>
        <field name="model">club.affiliate</field>
        <field name="arch" type="xml">
            <graph string="Afiliados por Tipo" type="pie">
                <field name="membership_type" type="row"/>
            </graph>
        </field>
    </record>

    <record id="action_dashboard_affiliates_type" model="ir.actions.act_window">
        <field name="name">Afiliados por Tipo</field>
        <field name="res_model">club.affiliate</field>
        <field name="view_mode">graph</field>
        <field name="view_id" ref="dashboard_affiliates_type_graph"/>
    </record>

    <!-- ============================================================ -->
    <!-- 2. MEMBRESÍAS POR ESTADO                                      -->
    <!-- ============================================================ -->
    <record id="dashboard_memberships_status_graph" model="ir.ui.view">
        <field name="name">dashboard.memberships.status.graph</field>
        <field name="model">club.membership</field>
        <field name="arch" type="xml">
            <graph string="Membresías por Estado" type="bar">
                <field name="status" type="row"/>
            </graph>
        </field>
    </record>

    <record id="action_dashboard_memberships_status" model="ir.actions.act_window">
        <field name="name">Membresías por Estado</field>
        <field name="res_model">club.membership</field>
        <field name="view_mode">graph</field>
        <field name="view_id" ref="dashboard_memberships_status_graph"/>
    </record>

    <!-- ============================================================ -->
    <!-- 3. ACCESOS POR TIPO DE PERSONA                                -->
    <!-- ============================================================ -->
    <record id="dashboard_access_person_search" model="ir.ui.view">
        <field name="name">dashboard.access.person.search</field>
        <field name="model">club.access.entry</field>
        <field name="arch" type="xml">
            <search string="Accesos por Tipo de Persona">
                <field name="person_type"/>
                <separator/>
                <filter name="this_month" string="Este Mes"
                        domain="[('entry_datetime', '&gt;=', (context_today() - relativedelta(day=1)).strftime('%Y-%m-%d')),
                                 ('entry_datetime', '&lt;', (context_today() + relativedelta(months=1, day=1)).strftime('%Y-%m-%d'))]"/>
                <filter name="this_quarter" string="Este Trimestre"
                        domain="[('entry_datetime', '&gt;=', (context_today() - relativedelta(month=((context_today().month - 1) // 3) * 3 + 1, day=1)).strftime('%Y-%m-%d')),
                                 ('entry_datetime', '&lt;', (context_today() + relativedelta(months=1, day=1)).strftime('%Y-%m-%d'))]"/>
                <filter name="this_year" string="Este Año"
                        domain="[('entry_datetime', '&gt;=', (context_today() - relativedelta(month=1, day=1)).strftime('%Y-%m-%d')),
                                 ('entry_datetime', '&lt;', (context_today() + relativedelta(months=1, day=1)).strftime('%Y-%m-%d'))]"/>
                <separator/>
                <filter name="granted" string="Acceso Concedido"
                        domain="[('access_status', '=', 'granted')]"/>
            </search>
        </field>
    </record>

    <record id="dashboard_access_person_graph" model="ir.ui.view">
        <field name="name">dashboard.access.person.graph</field>
        <field name="model">club.access.entry</field>
        <field name="arch" type="xml">
            <graph string="Accesos por Tipo de Persona" type="bar">
                <field name="person_type" type="row"/>
            </graph>
        </field>
    </record>

    <record id="action_dashboard_access_person" model="ir.actions.act_window">
        <field name="name">Accesos por Tipo de Persona</field>
        <field name="res_model">club.access.entry</field>
        <field name="view_mode">graph</field>
        <field name="view_id" ref="dashboard_access_person_graph"/>
        <field name="search_view_id" ref="dashboard_access_person_search"/>
        <field name="context">{'search_default_this_month': 1, 'search_default_granted': 1}</field>
    </record>

    <!-- ============================================================ -->
    <!-- 4. ACCESOS POR PUNTO DE CONTROL                               -->
    <!-- ============================================================ -->
    <record id="dashboard_access_checkpoint_search" model="ir.ui.view">
        <field name="name">dashboard.access.checkpoint.search</field>
        <field name="model">club.access.entry</field>
        <field name="arch" type="xml">
            <search string="Accesos por Punto de Control">
                <field name="checkpoint_id"/>
                <separator/>
                <filter name="this_month" string="Este Mes"
                        domain="[('entry_datetime', '&gt;=', (context_today() - relativedelta(day=1)).strftime('%Y-%m-%d')),
                                 ('entry_datetime', '&lt;', (context_today() + relativedelta(months=1, day=1)).strftime('%Y-%m-%d'))]"/>
                <filter name="this_quarter" string="Este Trimestre"
                        domain="[('entry_datetime', '&gt;=', (context_today() - relativedelta(month=((context_today().month - 1) // 3) * 3 + 1, day=1)).strftime('%Y-%m-%d')),
                                 ('entry_datetime', '&lt;', (context_today() + relativedelta(months=1, day=1)).strftime('%Y-%m-%d'))]"/>
                <filter name="this_year" string="Este Año"
                        domain="[('entry_datetime', '&gt;=', (context_today() - relativedelta(month=1, day=1)).strftime('%Y-%m-%d')),
                                 ('entry_datetime', '&lt;', (context_today() + relativedelta(months=1, day=1)).strftime('%Y-%m-%d'))]"/>
                <separator/>
                <filter name="granted" string="Acceso Concedido"
                        domain="[('access_status', '=', 'granted')]"/>
            </search>
        </field>
    </record>

    <record id="dashboard_access_checkpoint_graph" model="ir.ui.view">
        <field name="name">dashboard.access.checkpoint.graph</field>
        <field name="model">club.access.entry</field>
        <field name="arch" type="xml">
            <graph string="Accesos por Punto de Control" type="bar">
                <field name="checkpoint_id" type="row"/>
                <field name="duration_minutes" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_dashboard_access_checkpoint" model="ir.actions.act_window">
        <field name="name">Accesos por Punto de Control</field>
        <field name="res_model">club.access.entry</field>
        <field name="view_mode">graph</field>
        <field name="view_id" ref="dashboard_access_checkpoint_graph"/>
        <field name="search_view_id" ref="dashboard_access_checkpoint_search"/>
        <field name="context">{'search_default_this_month': 1, 'search_default_granted': 1}</field>
    </record>

    <!-- ============================================================ -->
    <!-- 5. PQR POR ESTADO                                             -->
    <!-- ============================================================ -->
    <record id="dashboard_pqr_status_search" model="ir.ui.view">
        <field name="name">dashboard.pqr.status.search</field>
        <field name="model">club.pqr.request</field>
        <field name="arch" type="xml">
            <search string="PQR por Estado">
                <field name="request_type"/>
                <field name="priority"/>
            </search>
        </field>
    </record>

    <record id="dashboard_pqr_status_graph" model="ir.ui.view">
        <field name="name">dashboard.pqr.status.graph</field>
        <field name="model">club.pqr.request</field>
        <field name="arch" type="xml">
            <graph string="PQR por Estado" type="bar">
                <field name="status" type="row"/>
            </graph>
        </field>
    </record>

    <record id="action_dashboard_pqr_status" model="ir.actions.act_window">
        <field name="name">PQR por Estado</field>
        <field name="res_model">club.pqr.request</field>
        <field name="view_mode">graph</field>
        <field name="view_id" ref="dashboard_pqr_status_graph"/>
        <field name="search_view_id" ref="dashboard_pqr_status_search"/>
    </record>

    <!-- ============================================================ -->
    <!-- 6. VISITAS DE INVITADOS POR ÁREA                              -->
    <!-- ============================================================ -->
    <record id="dashboard_guest_visits_search" model="ir.ui.view">
        <field name="name">dashboard.guest.visits.search</field>
        <field name="model">club.guest.visit</field>
        <field name="arch" type="xml">
            <search string="Visitas de Invitados por Área">
                <field name="areas_accessed"/>
                <separator/>
                <filter name="this_month" string="Este Mes"
                        domain="[('date', '&gt;=', (context_today() - relativedelta(day=1)).strftime('%Y-%m-%d')),
                                 ('date', '&lt;=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter name="this_quarter" string="Este Trimestre"
                        domain="[('date', '&gt;=', (context_today() - relativedelta(month=((context_today().month - 1) // 3) * 3 + 1, day=1)).strftime('%Y-%m-%d')),
                                 ('date', '&lt;=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter name="this_year" string="Este Año"
                        domain="[('date', '&gt;=', (context_today() - relativedelta(month=1, day=1)).strftime('%Y-%m-%d')),
                                 ('date', '&lt;=', context_today().strftime('%Y-%m-%d'))]"/>
                <separator/>
                <filter name="status_active" string="Activas"
                        domain="[('status', '=', 'active')]"/>
            </search>
        </field>
    </record>

    <record id="dashboard_guest_visits_graph" model="ir.ui.view">
        <field name="name">dashboard.guest.visits.graph</field>
        <field name="model">club.guest.visit</field>
        <field name="arch" type="xml">
            <graph string="Visitas de Invitados por Área" type="bar">
                <field name="areas_accessed" type="row"/>
            </graph>
        </field>
    </record>

    <record id="action_dashboard_guest_visits" model="ir.actions.act_window">
        <field name="name">Visitas de Invitados por Área</field>
        <field name="res_model">club.guest.visit</field>
        <field name="view_mode">graph</field>
        <field name="view_id" ref="dashboard_guest_visits_graph"/>
        <field name="search_view_id" ref="dashboard_guest_visits_search"/>
        <field name="context">{'search_default_this_month': 1}</field>
    </record>

    <!-- ============================================================ -->
    <!-- 7. FACTURACIÓN DE AFILIADOS                                   -->
    <!-- ============================================================ -->
    <record id="dashboard_affiliate_billing_graph" model="ir.ui.view">
        <field name="name">dashboard.affiliate.billing.graph</field>
        <field name="model">club.affiliate.billing.invoice</field>
        <field name="arch" type="xml">
            <graph string="Facturación de Afiliados" type="bar">
                <field name="invoice_status" type="row"/>
                <field name="total_amount" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_dashboard_affiliate_billing" model="ir.actions.act_window">
        <field name="name">Facturación de Afiliados</field>
        <field name="res_model">club.affiliate.billing.invoice</field>
        <field name="view_mode">graph</field>
        <field name="view_id" ref="dashboard_affiliate_billing_graph"/>
    </record>

</odoo>
