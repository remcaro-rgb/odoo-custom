<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view -->
    <record id="view_club_arena_list" model="ir.ui.view">
        <field name="name">club.arena.list</field>
        <field name="model">club.arena</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="arena_type" widget="badge"/>
                <field name="capacity"/>
                <field name="under_maintenance"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_club_arena_form" model="ir.ui.view">
        <field name="name">club.arena.form</field>
        <field name="model">club.arena</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Arena Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="arena_type"/>
                            <field name="capacity"/>
                        </group>
                        <group>
                            <field name="under_maintenance"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Bookings" name="bookings">
                            <field name="booking_ids">
                                <list>
                                    <field name="affiliate_id"/>
                                    <field name="horse_id"/>
                                    <field name="date"/>
                                    <field name="time_slot" widget="float_time"/>
                                    <field name="duration"/>
                                    <field name="status" widget="badge"
                                        decoration-success="status == 'booked'"
                                        decoration-info="status == 'completed'"
                                        decoration-muted="status == 'cancelled'"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_club_arena_search" model="ir.ui.view">
        <field name="name">club.arena.search</field>
        <field name="model">club.arena</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <filter name="available" string="Available"
                    domain="[('under_maintenance', '=', False)]"/>
                <filter name="maintenance" string="Under Maintenance"
                    domain="[('under_maintenance', '=', True)]"/>
                <group expand="0" string="Group By">
                    <filter name="group_type" string="Type"
                        context="{'group_by': 'arena_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_club_arena" model="ir.actions.act_window">
        <field name="name">Arenas</field>
        <field name="res_model">club.arena</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_club_arena_search"/>
        <field name="path">club-arenas</field>
    </record>

</odoo>
