<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="cron_vet_visit_alert" model="ir.cron">
            <field name="name">Equestrian: Vet Visit Reminder</field>
            <field name="model_id" ref="model_club_vet_record"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_vet_visits()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

    </data>
</odoo>
