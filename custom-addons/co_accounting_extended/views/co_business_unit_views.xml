<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Action for journal items stat button (must precede form that references it) -->
    <record id="action_co_business_unit_move_lines" model="ir.actions.act_window">
        <field name="name">Journal Items</field>
        <field name="res_model">account.move.line</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('business_unit_id', '=', active_id)]</field>
        <field name="path">co-business-unit-items</field>
    </record>

    <!-- Tree View -->
    <record id="co_business_unit_view_list" model="ir.ui.view">
        <field name="name">co.business.unit.list</field>
        <field name="model">co.business.unit</field>
        <field name="arch" type="xml">
            <list string="Business Units">
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="analytic_account_id"/>
                <field name="responsible_id" widget="many2one_avatar_user"/>
                <field name="move_line_count" string="Items"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="co_business_unit_view_form" model="ir.ui.view">
        <field name="name">co.business.unit.form</field>
        <field name="model">co.business.unit</field>
        <field name="arch" type="xml">
            <form string="Business Unit">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(co_accounting_extended.action_co_business_unit_move_lines)d"
                                type="action"
                                class="oe_stat_button"
                                icon="fa-list"
                                invisible="move_line_count == 0">
                            <field name="move_line_count" widget="statinfo" string="Journal Items"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g., Hotel"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="analytic_account_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="responsible_id" widget="many2one_avatar_user"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description" placeholder="Describe this business unit..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="co_business_unit_view_search" model="ir.ui.view">
        <field name="name">co.business.unit.search</field>
        <field name="model">co.business.unit</field>
        <field name="arch" type="xml">
            <search string="Business Units">
                <field name="name" string="Name or Code"
                       filter_domain="['|', ('name', 'ilike', self), ('code', 'ilike', self)]"/>
                <field name="responsible_id"/>
                <field name="analytic_account_id"/>
                <filter name="archived" string="Archived"
                        domain="[('active', '=', False)]"/>
                <group>
                    <filter name="group_responsible" string="Responsible"
                            context="{'group_by': 'responsible_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_co_business_unit" model="ir.actions.act_window">
        <field name="name">Business Units</field>
        <field name="res_model">co.business.unit</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="co_business_unit_view_search"/>
        <field name="path">co-business-units</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first business unit
            </p>
            <p>
                Business units represent operational segments such as
                Hotel, Restaurant, Spa, etc.
            </p>
        </field>
    </record>

</odoo>
