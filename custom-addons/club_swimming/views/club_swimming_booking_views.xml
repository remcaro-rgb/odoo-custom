<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view -->
    <record id="view_club_swimming_booking_list" model="ir.ui.view">
        <field name="name">club.swimming.booking.list</field>
        <field name="model">club.swimming.booking</field>
        <field name="arch" type="xml">
            <list>
                <field name="affiliate_id"/>
                <field name="pool_id"/>
                <field name="lane_id" optional="show"/>
                <field name="date"/>
                <field name="time_slot" widget="float_time"/>
                <field name="duration"/>
                <field name="guest_count"/>
                <field name="status" widget="badge"
                    decoration-success="status == 'active'"
                    decoration-info="status == 'booked'"
                    decoration-warning="status == 'completed'"
                    decoration-danger="status == 'cancelled'"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_club_swimming_booking_form" model="ir.ui.view">
        <field name="name">club.swimming.booking.form</field>
        <field name="model">club.swimming.booking</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="status" widget="statusbar"
                        statusbar_visible="booked,active,completed"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="affiliate_id"/>
                            <field name="pool_id"/>
                            <field name="lane_id" domain="[('pool_id', '=', pool_id)]"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="time_slot" widget="float_time"/>
                            <field name="duration"/>
                            <field name="guest_count"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_club_swimming_booking_search" model="ir.ui.view">
        <field name="name">club.swimming.booking.search</field>
        <field name="model">club.swimming.booking</field>
        <field name="arch" type="xml">
            <search>
                <field name="affiliate_id"/>
                <field name="pool_id"/>
                <filter name="booked" string="Booked"
                    domain="[('status', '=', 'booked')]"/>
                <filter name="active_bookings" string="Active"
                    domain="[('status', '=', 'active')]"/>
                <filter name="today" string="Today"
                    domain="[('date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Group By">
                    <filter name="group_pool" string="Pool"
                        context="{'group_by': 'pool_id'}"/>
                    <filter name="group_status" string="Status"
                        context="{'group_by': 'status'}"/>
                    <filter name="group_date" string="Date"
                        context="{'group_by': 'date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_club_swimming_booking" model="ir.actions.act_window">
        <field name="name">Bookings</field>
        <field name="res_model">club.swimming.booking</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_club_swimming_booking_search"/>
        <field name="path">club-swimming-bookings</field>
    </record>

</odoo>
