<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view -->
    <record id="view_club_swimming_class_list" model="ir.ui.view">
        <field name="name">club.swimming.class.list</field>
        <field name="model">club.swimming.class</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="pool_id"/>
                <field name="instructor_id"/>
                <field name="day_of_week"/>
                <field name="time_slot" widget="float_time"/>
                <field name="duration"/>
                <field name="level" widget="badge"/>
                <field name="max_students"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_club_swimming_class_form" model="ir.ui.view">
        <field name="name">club.swimming.class.form</field>
        <field name="model">club.swimming.class</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. Adult Beginner"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="pool_id"/>
                            <field name="instructor_id"/>
                            <field name="level"/>
                        </group>
                        <group>
                            <field name="day_of_week"/>
                            <field name="time_slot" widget="float_time"/>
                            <field name="duration"/>
                            <field name="max_students"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Students" name="students">
                            <field name="student_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="affiliate_number"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_club_swimming_class_search" model="ir.ui.view">
        <field name="name">club.swimming.class.search</field>
        <field name="model">club.swimming.class</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="pool_id"/>
                <field name="instructor_id"/>
                <group expand="0" string="Group By">
                    <filter name="group_level" string="Level"
                        context="{'group_by': 'level'}"/>
                    <filter name="group_day" string="Day of Week"
                        context="{'group_by': 'day_of_week'}"/>
                    <filter name="group_pool" string="Pool"
                        context="{'group_by': 'pool_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_club_swimming_class" model="ir.actions.act_window">
        <field name="name">Classes</field>
        <field name="res_model">club.swimming.class</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_club_swimming_class_search"/>
        <field name="path">club-swimming-classes</field>
    </record>

</odoo>
