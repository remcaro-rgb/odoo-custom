<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Kiosk session sequence -->
        <record id="seq_pms_kiosk_session" model="ir.sequence">
            <field name="name">PMS Kiosk Session</field>
            <field name="code">pms.kiosk.session</field>
            <field name="prefix">KIOSK-</field>
            <field name="padding">5</field>
        </record>

        <!-- Daily RMS cron -->
        <record id="cron_rms_daily" model="ir.cron">
            <field name="name">PMS: Daily Revenue Management</field>
            <field name="model_id" ref="model_pms_property"/>
            <field name="state">code</field>
            <field name="code">
for prop in model.search([]):
    prop.action_run_rms()
            </field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

    </data>
</odoo>
