<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view -->
    <record id="view_pms_revenue_rule_list" model="ir.ui.view">
        <field name="name">pms.revenue.rule.list</field>
        <field name="model">pms.revenue.rule</field>
        <field name="arch" type="xml">
            <list>
                <field name="priority" widget="handle"/>
                <field name="name"/>
                <field name="property_id"/>
                <field name="rule_type" widget="badge"/>
                <field name="action_type"/>
                <field name="multiplier"
                    invisible="action_type != 'multiplier'"/>
                <field name="fixed_amount"
                    invisible="action_type != 'fixed_adjustment'"/>
                <field name="is_active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_pms_revenue_rule_form" model="ir.ui.view">
        <field name="name">pms.revenue.rule.form</field>
        <field name="model">pms.revenue.rule</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Rule name..."/></h1>
                    </div>
                    <group>
                        <group string="General">
                            <field name="property_id"/>
                            <field name="rule_type"/>
                            <field name="room_type_ids"
                                widget="many2many_tags"
                                domain="[('property_id', '=', property_id)]"/>
                            <field name="priority"/>
                            <field name="is_active"/>
                        </group>
                        <group string="Action">
                            <field name="action_type"/>
                            <field name="multiplier"
                                invisible="action_type != 'multiplier'"/>
                            <field name="fixed_amount"
                                invisible="action_type != 'fixed_adjustment'"/>
                            <field name="min_rate"
                                invisible="action_type != 'set_min_rate'"/>
                            <field name="max_rate"
                                invisible="action_type != 'set_max_rate'"/>
                        </group>
                    </group>
                    <group string="Conditions">
                        <group>
                            <field name="occupancy_min"
                                invisible="rule_type not in ('occupancy_based',)"/>
                            <field name="occupancy_max"
                                invisible="rule_type not in ('occupancy_based',)"/>
                            <field name="lead_time_min"
                                invisible="rule_type != 'lead_time'"/>
                            <field name="lead_time_max"
                                invisible="rule_type != 'lead_time'"/>
                        </group>
                        <group>
                            <field name="day_of_week_ids"
                                invisible="rule_type != 'day_of_week'"/>
                            <field name="date_from"
                                invisible="rule_type != 'season'"/>
                            <field name="date_to"
                                invisible="rule_type != 'season'"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_pms_revenue_rule_search" model="ir.ui.view">
        <field name="name">pms.revenue.rule.search</field>
        <field name="model">pms.revenue.rule</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="property_id"/>
                <field name="rule_type"/>
                <filter name="active_rules" string="Active"
                    domain="[('is_active', '=', True)]"/>
                <filter name="inactive_rules" string="Inactive"
                    domain="[('is_active', '=', False)]"/>
                <separator/>
                <group>
                    <filter name="group_type" string="Rule Type"
                        context="{'group_by': 'rule_type'}"/>
                    <filter name="group_property" string="Property"
                        context="{'group_by': 'property_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_pms_revenue_rule" model="ir.actions.act_window">
        <field name="name">Revenue Rules</field>
        <field name="res_model">pms.revenue.rule</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_pms_revenue_rule_search"/>
        <field name="context">{'search_default_active_rules': 1}</field>
        <field name="path">pms-revenue-rules</field>
    </record>

</odoo>
