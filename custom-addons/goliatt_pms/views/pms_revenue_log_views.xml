<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view (read-only) -->
    <record id="view_pms_revenue_log_list" model="ir.ui.view">
        <field name="name">pms.revenue.log.list</field>
        <field name="model">pms.revenue.log</field>
        <field name="arch" type="xml">
            <list create="0" edit="0" delete="0"
                decoration-success="change_pct &gt; 0"
                decoration-danger="change_pct &lt; 0">
                <field name="change_datetime"/>
                <field name="property_id"/>
                <field name="room_type_id"/>
                <field name="date"/>
                <field name="old_rate"/>
                <field name="new_rate"/>
                <field name="change_pct" widget="badge"
                    decoration-success="change_pct &gt; 0"
                    decoration-danger="change_pct &lt; 0"/>
                <field name="reason"/>
                <field name="changed_by"/>
            </list>
        </field>
    </record>

    <!-- Form view (read-only) -->
    <record id="view_pms_revenue_log_form" model="ir.ui.view">
        <field name="name">pms.revenue.log.form</field>
        <field name="model">pms.revenue.log</field>
        <field name="arch" type="xml">
            <form create="0" edit="0" delete="0">
                <sheet>
                    <group>
                        <group>
                            <field name="property_id"/>
                            <field name="room_type_id"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="old_rate"/>
                            <field name="new_rate"/>
                            <field name="change_pct"/>
                            <field name="reason"/>
                            <field name="changed_by"/>
                            <field name="change_datetime"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_pms_revenue_log_search" model="ir.ui.view">
        <field name="name">pms.revenue.log.search</field>
        <field name="model">pms.revenue.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="property_id"/>
                <field name="room_type_id"/>
                <field name="reason"/>
                <group>
                    <filter name="group_property" string="Property"
                        context="{'group_by': 'property_id'}"/>
                    <filter name="group_room_type" string="Room Type"
                        context="{'group_by': 'room_type_id'}"/>
                    <filter name="group_date" string="Date"
                        context="{'group_by': 'date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_pms_revenue_log" model="ir.actions.act_window">
        <field name="name">Revenue Log</field>
        <field name="res_model">pms.revenue.log</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_pms_revenue_log_search"/>
        <field name="path">pms-revenue-log</field>
    </record>

</odoo>
