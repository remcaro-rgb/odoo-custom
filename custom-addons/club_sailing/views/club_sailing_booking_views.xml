<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view -->
    <record id="view_club_sailing_booking_list" model="ir.ui.view">
        <field name="name">club.sailing.booking.list</field>
        <field name="model">club.sailing.booking</field>
        <field name="arch" type="xml">
            <list>
                <field name="date"/>
                <field name="time_slot" widget="float_time"/>
                <field name="duration" widget="float_time"/>
                <field name="affiliate_id"/>
                <field name="boat_id"/>
                <field name="dock_id"/>
                <field name="passenger_count"/>
                <field name="status" widget="badge"
                    decoration-success="status == 'booked'"
                    decoration-info="status == 'in_progress'"
                    decoration-muted="status == 'completed'"
                    decoration-danger="status == 'cancelled'"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_club_sailing_booking_form" model="ir.ui.view">
        <field name="name">club.sailing.booking.form</field>
        <field name="model">club.sailing.booking</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="affiliate_id"/>
                            <field name="boat_id"/>
                            <field name="dock_id"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="time_slot" widget="float_time"/>
                            <field name="duration" widget="float_time"/>
                            <field name="passenger_count"/>
                            <field name="status" widget="badge"
                                decoration-success="status == 'booked'"
                                decoration-info="status == 'in_progress'"
                                decoration-muted="status == 'completed'"
                                decoration-danger="status == 'cancelled'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes" name="notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_club_sailing_booking_search" model="ir.ui.view">
        <field name="name">club.sailing.booking.search</field>
        <field name="model">club.sailing.booking</field>
        <field name="arch" type="xml">
            <search>
                <field name="affiliate_id"/>
                <field name="boat_id"/>
                <field name="dock_id"/>
                <filter name="booked" string="Booked"
                    domain="[('status','=','booked')]"/>
                <filter name="in_progress" string="In Progress"
                    domain="[('status','=','in_progress')]"/>
                <filter name="completed" string="Completed"
                    domain="[('status','=','completed')]"/>
                <filter name="cancelled" string="Cancelled"
                    domain="[('status','=','cancelled')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_boat" string="Boat"
                        context="{'group_by': 'boat_id'}"/>
                    <filter name="group_date" string="Date"
                        context="{'group_by': 'date'}"/>
                    <filter name="group_status" string="Status"
                        context="{'group_by': 'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_club_sailing_booking" model="ir.actions.act_window">
        <field name="name">Bookings</field>
        <field name="res_model">club.sailing.booking</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_club_sailing_booking_search"/>
        <field name="context">{'search_default_booked': 1}</field>
        <field name="path">club-sailing-bookings</field>
    </record>

</odoo>
