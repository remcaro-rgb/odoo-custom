<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view -->
    <record id="view_club_sailing_crew_list" model="ir.ui.view">
        <field name="name">club.sailing.crew.list</field>
        <field name="model">club.sailing.crew</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="role"/>
                <field name="certification"/>
                <field name="partner_id"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_club_sailing_crew_form" model="ir.ui.view">
        <field name="name">club.sailing.crew.form</field>
        <field name="model">club.sailing.crew</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="role"/>
                            <field name="certification"/>
                        </group>
                        <group>
                            <field name="partner_id"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_club_sailing_crew_search" model="ir.ui.view">
        <field name="name">club.sailing.crew.search</field>
        <field name="model">club.sailing.crew</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="certification"/>
                <filter name="active" string="Active"
                    domain="[('active','=',True)]"/>
                <filter name="inactive" string="Archived"
                    domain="[('active','=',False)]"/>
                <group expand="0" string="Group By">
                    <filter name="group_role" string="Role"
                        context="{'group_by': 'role'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_club_sailing_crew" model="ir.actions.act_window">
        <field name="name">Crew</field>
        <field name="res_model">club.sailing.crew</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_club_sailing_crew_search"/>
        <field name="path">club-sailing-crew</field>
    </record>

</odoo>
