<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view (editable) -->
    <record id="view_club_faq_category_list" model="ir.ui.view">
        <field name="name">club.faq.category.list</field>
        <field name="model">club.faq.category</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="icon" optional="hide"/>
                <field name="faq_count" string="# FAQs"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_club_faq_category_form" model="ir.ui.view">
        <field name="name">club.faq.category.form</field>
        <field name="model">club.faq.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Category name..."/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="sequence"/>
                            <field name="icon"/>
                        </group>
                        <group>
                            <field name="faq_count" string="# FAQs"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="FAQ Items" name="faq_items">
                            <field name="faq_ids">
                                <list>
                                    <field name="sequence" widget="handle"/>
                                    <field name="question"/>
                                    <field name="is_published"/>
                                    <field name="helpful_count"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_club_faq_category" model="ir.actions.act_window">
        <field name="name">FAQ Categories</field>
        <field name="res_model">club.faq.category</field>
        <field name="view_mode">list,form</field>
        <field name="path">club-faq-categories</field>
    </record>

</odoo>
