<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_co_budget" model="ir.module.category">
        <field name="name">Budget Management</field>
        <field name="sequence">20</field>
    </record>

    <record id="group_co_budget_user" model="res.groups">
        <field name="name">Budget User</field>
        <field name="implied_ids" eval="[(4, ref('account.group_account_user'))]"/>
    </record>

    <record id="group_co_budget_manager" model="res.groups">
        <field name="name">Budget Manager</field>
        <field name="implied_ids" eval="[(4, ref('co_budget.group_co_budget_user'))]"/>
    </record>

    <!-- Multi-company record rule -->
    <record id="co_budget_comp_rule" model="ir.rule">
        <field name="name">Budget: multi-company</field>
        <field name="model_id" ref="model_co_budget"/>
        <field name="domain_force">[
            '|',
            ('company_id', '=', False),
            ('company_id', 'in', company_ids),
        ]</field>
    </record>

    <record id="co_budget_line_comp_rule" model="ir.rule">
        <field name="name">Budget Line: multi-company</field>
        <field name="model_id" ref="model_co_budget_line"/>
        <field name="domain_force">[
            '|',
            ('company_id', '=', False),
            ('company_id', 'in', company_ids),
        ]</field>
    </record>

    <record id="co_budget_position_comp_rule" model="ir.rule">
        <field name="name">Budget Position: multi-company</field>
        <field name="model_id" ref="model_co_budget_position"/>
        <field name="domain_force">[
            '|',
            ('company_id', '=', False),
            ('company_id', 'in', company_ids),
        ]</field>
    </record>
</odoo>
