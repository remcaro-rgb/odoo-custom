<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ── Security Groups ──────────────────────────────────────── -->

        <record id="group_job_staff" model="res.groups">
            <field name="name">Job Offers Staff</field>
            <field name="category_id" ref="base.module_category_hidden"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- ── Record Rules ─────────────────────────────────────────── -->

        <!-- Portal / Member: see only published offers + own posted offers -->
        <record id="rule_job_offer_member" model="ir.rule">
            <field name="name">Job Offer: member sees published + own</field>
            <field name="model_id" ref="model_club_job_offer"/>
            <field name="domain_force">[
                '|',
                ('status', '=', 'published'),
                ('affiliate_id.partner_id', '=', user.partner_id.id)
            ]</field>
            <field name="groups" eval="[(4, ref('club_core.group_club_member'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Portal / Member: see only own applications -->
        <record id="rule_job_application_member" model="ir.rule">
            <field name="name">Job Application: member sees own</field>
            <field name="model_id" ref="model_club_job_application"/>
            <field name="domain_force">[
                '|',
                ('applicant_affiliate_id.partner_id', '=', user.partner_id.id),
                ('offer_id.affiliate_id.partner_id', '=', user.partner_id.id)
            ]</field>
            <field name="groups" eval="[(4, ref('club_core.group_club_member'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

    </data>
</odoo>
