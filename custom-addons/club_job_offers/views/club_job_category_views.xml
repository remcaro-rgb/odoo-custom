<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view -->
    <record id="view_club_job_category_list" model="ir.ui.view">
        <field name="name">club.job.category.list</field>
        <field name="model">club.job.category</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_club_job_category_form" model="ir.ui.view">
        <field name="name">club.job.category.form</field>
        <field name="model">club.job.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_club_job_category" model="ir.actions.act_window">
        <field name="name">Job Categories</field>
        <field name="res_model">club.job.category</field>
        <field name="view_mode">list,form</field>
        <field name="path">club-job-categories</field>
    </record>

</odoo>
