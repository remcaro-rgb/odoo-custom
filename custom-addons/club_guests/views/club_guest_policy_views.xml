<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view -->
    <record id="view_club_guest_policy_list" model="ir.ui.view">
        <field name="name">club.guest.policy.list</field>
        <field name="model">club.guest.policy</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="max_guests_per_visit"/>
                <field name="max_visits_per_month"/>
                <field name="requires_advance_registration"/>
                <field name="guest_fee"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_club_guest_policy_form" model="ir.ui.view">
        <field name="name">club.guest.policy.form</field>
        <field name="model">club.guest.policy</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Policy Name"/></h1>
                    </div>
                    <group>
                        <group string="Limits">
                            <field name="max_guests_per_visit"/>
                            <field name="max_visits_per_month"/>
                        </group>
                        <group string="Settings">
                            <field name="requires_advance_registration"/>
                            <field name="guest_fee"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_club_guest_policy" model="ir.actions.act_window">
        <field name="name">Guest Policies</field>
        <field name="res_model">club.guest.policy</field>
        <field name="view_mode">list,form</field>
        <field name="path">club-guest-policies</field>
    </record>

</odoo>
