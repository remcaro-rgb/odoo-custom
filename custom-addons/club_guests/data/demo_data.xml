<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ── Guest Policy ────────────────────────────────────────── -->

        <record id="policy_standard" model="club.guest.policy">
            <field name="name">Standard Guest Policy</field>
            <field name="max_guests_per_visit">4</field>
            <field name="max_visits_per_month">8</field>
            <field name="requires_advance_registration" eval="True"/>
            <field name="guest_fee">25.00</field>
        </record>

        <!-- ── Guests ──────────────────────────────────────────────── -->

        <record id="guest_miguel" model="club.guest">
