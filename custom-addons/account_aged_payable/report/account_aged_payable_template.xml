<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="account_aged_payable_document">
        <t t-call="web.html_container">

            <!-- Custom repeating page header: logo + company name + page numbers -->
            <div class="header">
                <div class="row" style="align-items: center; padding: 4px 0;">
                    <div class="col-2" style="text-align: left;">
                        <img t-if="company.logo"
                             t-attf-src="/web/image/res.company/{{ company.id }}/logo"
                             style="max-height: 48px; max-width: 120px; object-fit: contain;"/>
                    </div>
                    <div class="col-7" style="padding-left: 8px;">
                        <span style="font-size: 15px; font-weight: 700; color: #2c3e50;">
                            <t t-out="company.name"/>
                        </span>
                    </div>
                    <div class="col-3 text-end" style="font-size: 11px; color: #555;">
                        Página <span class="page"/> de <span class="topage"/>
                    </div>
                </div>
            </div>

            <div class="article">
            <div class="page">

                <!-- Print metadata -->
                <div class="text-end mb-2" style="font-size: 11px; color: #555; line-height: 1.6;">
                    <div>Impreso por: <strong><t t-out="user.name"/></strong></div>
                    <div>Fecha impresión: <t t-out="print_date" t-options='{"widget": "datetime"}'/></div>
                </div>

                <!-- Report title banner -->
                <div style="background-color: #2c3e50; color: #ffffff; padding: 8px 12px; margin-bottom: 4px;">
                    <div style="font-size: 18px; font-weight: 700; letter-spacing: 1px; text-align: center;">
                        CARTERA POR EDADES - CUENTAS POR PAGAR
                    </div>
                    <div style="font-size: 12px; text-align: center; opacity: 0.85;">
                        Al: <t t-out="report_date" t-options='{"widget": "date"}'/>
                    </div>
                </div>
                <div style="height: 12px;"/>

                <!-- Aging summary table -->
                <table class="table table-sm table-bordered" style="font-size: 11px;">
                    <thead>
                        <tr style="background-color: #d6e4f0; color: #1a252f; font-weight: 600; text-align: center;">
                            <th style="text-align: left; width: 28%;">Proveedor</th>
                            <t t-foreach="bucket_labels" t-as="label">
                                <th style="text-align: right; width: 10%;"><t t-out="label"/></th>
                            </t>
                            <th style="text-align: right; width: 12%;">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="rows" t-as="row">
                            <tr>
                                <td style="padding: 3px 6px;"><t t-out="row['partner']"/></td>
                                <t t-foreach="row['bucket_amounts']" t-as="amt">
                                    <td style="text-align: right; font-family: monospace; white-space: nowrap; padding: 3px 6px;">
                                        <t t-out="amt"/>
                                    </td>
                                </t>
                                <td style="text-align: right; font-family: monospace; white-space: nowrap; font-weight: 600; padding: 3px 6px;">
                                    <t t-out="row['total']"/>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                    <tfoot>
                        <tr style="background-color: #eaf2fb; font-weight: 700;">
                            <td style="padding: 4px 6px;">TOTAL</td>
                            <t t-foreach="grand_totals" t-as="gt">
                                <td style="text-align: right; font-family: monospace; white-space: nowrap; border-top: 2px solid #2c3e50; padding: 4px 6px;">
                                    <t t-out="gt"/>
                                </td>
                            </t>
                            <td style="text-align: right; font-family: monospace; white-space: nowrap; border-top: 2px solid #2c3e50; font-weight: 700; padding: 4px 6px;">
                                <t t-out="grand_total"/>
                            </td>
                        </tr>
                    </tfoot>
                </table>

            </div>
            </div>

        </t>
    </template>

    <record id="action_report_account_aged_payable" model="ir.actions.report">
        <field name="name">Cartera por Pagar</field>
        <field name="model">account.aged.payable</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">account_aged_payable.account_aged_payable_document</field>
        <field name="report_file">account_aged_payable.account_aged_payable_document</field>
        <field name="binding_model_id" ref="model_account_aged_payable"/>
        <field name="binding_type">report</field>
    </record>
</odoo>
