<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="seq_club_lost_item" model="ir.sequence">
            <field name="name">Club Lost Item</field>
            <field name="code">club.lost.item</field>
            <field name="prefix">LOST-</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <record id="seq_club_found_item" model="ir.sequence">
            <field name="name">Club Found Item</field>
            <field name="code">club.found.item</field>
            <field name="prefix">FOUND-</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

    </data>
</odoo>
