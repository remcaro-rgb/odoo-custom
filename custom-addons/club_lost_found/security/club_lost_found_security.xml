<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ── Security Groups ──────────────────────────────────────── -->

        <record id="group_lost_found_staff" model="res.groups">
            <field name="name">Lost &amp; Found Staff</field>
            <field name="category_id" ref="base.module_category_hidden"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- ── Record Rules ─────────────────────────────────────────── -->

        <!-- Lost Item: portal member sees only own reports -->
        <record id="rule_lost_item_portal_own" model="ir.rule">
            <field name="name">Lost Item: portal sees own reports</field>
            <field name="model_id" ref="model_club_lost_item"/>
            <field name="domain_force">[('reporter_id.partner_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('club_core.group_club_member'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Found Item: portal member read-only access (no record rule restriction) -->
        <!-- Found items are publicly browsable by members, no ownership filter -->

    </data>
</odoo>
