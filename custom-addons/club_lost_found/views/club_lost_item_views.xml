<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view -->
    <record id="view_club_lost_item_list" model="ir.ui.view">
        <field name="name">club.lost.item.list</field>
        <field name="model">club.lost.item</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="reporter_id"/>
                <field name="description"/>
                <field name="category"/>
                <field name="location_lost"/>
                <field name="date_lost"/>
                <field name="date_reported"/>
                <field name="status" widget="badge"
                    decoration-info="status == 'reported'"
                    decoration-warning="status == 'matched'"
                    decoration-success="status == 'claimed'"
                    decoration-muted="status == 'closed'"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_club_lost_item_form" model="ir.ui.view">
        <field name="name">club.lost.item.form</field>
        <field name="model">club.lost.item</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_match_wizard"
                        string="Match"
                        type="object"
                        class="oe_highlight"
                        invisible="status != 'reported'"/>
                    <button name="action_close"
                        string="Close"
                        type="object"
                        invisible="status in ('closed',)"
                        confirm="Are you sure you want to close this lost item report?"/>
                    <field name="status" widget="statusbar"
                        statusbar_visible="reported,matched,claimed,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="reporter_id"/>
                            <field name="category"/>
                            <field name="date_lost"/>
                            <field name="date_reported"/>
                        </group>
                        <group>
                            <field name="location_lost"/>
                            <field name="matched_found_id" readonly="1"/>
                            <field name="photo" widget="image" class="oe_avatar"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description" placeholder="Describe the lost item in detail..."/>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Additional notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_club_lost_item_search" model="ir.ui.view">
        <field name="name">club.lost.item.search</field>
        <field name="model">club.lost.item</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="reporter_id"/>
                <field name="description"/>
                <field name="location_lost"/>
                <separator/>
                <filter name="reported" string="Reported"
                    domain="[('status','=','reported')]"/>
                <filter name="matched" string="Matched"
                    domain="[('status','=','matched')]"/>
                <filter name="claimed" string="Claimed"
                    domain="[('status','=','claimed')]"/>
                <filter name="closed" string="Closed"
                    domain="[('status','=','closed')]"/>
                <separator/>
                <filter name="date_lost_this_month" string="Lost This Month"
                    domain="[('date_lost','&gt;=', (context_today() - relativedelta(day=1)).strftime('%%Y-%%m-%%d')),
                             ('date_lost','&lt;=', context_today().strftime('%%Y-%%m-%%d'))]"/>
                <group expand="0" string="Group By">
                    <filter name="group_category" string="Category"
                        context="{'group_by': 'category'}"/>
                    <filter name="group_status" string="Status"
                        context="{'group_by': 'status'}"/>
                    <filter name="group_date_reported" string="Date Reported"
                        context="{'group_by': 'date_reported'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_club_lost_item" model="ir.actions.act_window">
        <field name="name">Lost Items</field>
        <field name="res_model">club.lost.item</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_club_lost_item_search"/>
        <field name="context">{'search_default_reported': 1}</field>
        <field name="path">club-lost-items</field>
    </record>

</odoo>
