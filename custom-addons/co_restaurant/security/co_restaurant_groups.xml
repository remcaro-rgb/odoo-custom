<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_restaurant" model="ir.module.category">
        <field name="name">Restaurant</field>
        <field name="description">Restaurant management: recipes, production, kardex, waste tracking.</field>
        <field name="sequence">50</field>
    </record>

    <record id="group_restaurant_user" model="res.groups">
        <field name="name">User</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_restaurant_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="implied_ids" eval="[(4, ref('group_restaurant_user'))]"/>
    </record>
</odoo>
