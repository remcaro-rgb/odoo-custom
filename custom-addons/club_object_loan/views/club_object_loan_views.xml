<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view -->
    <record id="view_club_object_loan_list" model="ir.ui.view">
        <field name="name">club.object.loan.list</field>
        <field name="model">club.object.loan</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="item_id"/>
                <field name="affiliate_id"/>
                <field name="loan_date"/>
                <field name="due_date"/>
                <field name="return_date"/>
                <field name="quantity"/>
                <field name="status" widget="badge"
                    decoration-success="status == 'returned'"
                    decoration-info="status == 'active'"
                    decoration-warning="status == 'overdue'"
                    decoration-danger="status == 'lost'"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_club_object_loan_form" model="ir.ui.view">
        <field name="name">club.object.loan.form</field>
        <field name="model">club.object.loan</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_return" type="object"
                        string="Return" class="oe_highlight"
                        invisible="status != 'active' and status != 'overdue'"/>
                    <button name="action_mark_lost" type="object"
                        string="Mark as Lost" class="btn-secondary"
                        invisible="status != 'active' and status != 'overdue'"
                        confirm="Are you sure you want to mark this item as lost?"/>
                    <field name="status" widget="statusbar"
                        statusbar_visible="active,returned"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="item_id"/>
                            <field name="category_id"/>
                            <field name="affiliate_id"/>
                            <field name="quantity"/>
                        </group>
                        <group>
                            <field name="loan_date"/>
                            <field name="due_date"/>
                            <field name="return_date"/>
                            <field name="is_overdue" invisible="not is_overdue"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Additional notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_club_object_loan_search" model="ir.ui.view">
        <field name="name">club.object.loan.search</field>
        <field name="model">club.object.loan</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="item_id"/>
                <field name="affiliate_id"/>
                <filter name="active_loans" string="Active"
                    domain="[('status','=','active')]"/>
                <filter name="overdue" string="Overdue"
                    domain="[('status','=','overdue')]"/>
                <filter name="returned" string="Returned"
                    domain="[('status','=','returned')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_status" string="Status"
                        context="{'group_by': 'status'}"/>
                    <filter name="group_category" string="Category"
                        context="{'group_by': 'category_id'}"/>
                    <filter name="group_item" string="Item"
                        context="{'group_by': 'item_id'}"/>
                    <filter name="group_affiliate" string="Affiliate"
                        context="{'group_by': 'affiliate_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_club_object_loan" model="ir.actions.act_window">
        <field name="name">Loans</field>
        <field name="res_model">club.object.loan</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_club_object_loan_search"/>
        <field name="context">{'search_default_active_loans': 1}</field>
        <field name="path">club-object-loans</field>
    </record>

</odoo>
