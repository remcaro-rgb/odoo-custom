<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Kanban view -->
    <record id="view_club_object_item_kanban" model="ir.ui.view">
        <field name="name">club.object.item.kanban</field>
        <field name="model">club.object.item</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="code"/>
                <field name="category_id"/>
                <field name="status"/>
                <field name="quantity_total"/>
                <field name="quantity_available"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <strong><field name="name"/></strong><br/>
                            <span class="text-muted"><field name="code"/></span><br/>
                            <span class="text-muted"><field name="category_id"/></span><br/>
                            <field name="status" widget="badge"
                                decoration-success="status == 'available'"
                                decoration-info="status == 'loaned'"
                                decoration-warning="status == 'maintenance'"
                                decoration-danger="status == 'retired'"/>
                            <div class="mt-1">
                                <span>Available: <field name="quantity_available"/> / <field name="quantity_total"/></span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- List view -->
    <record id="view_club_object_item_list" model="ir.ui.view">
        <field name="name">club.object.item.list</field>
        <field name="model">club.object.item</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="category_id"/>
                <field name="status" widget="badge"
                    decoration-success="status == 'available'"
                    decoration-info="status == 'loaned'"
                    decoration-warning="status == 'maintenance'"
                    decoration-danger="status == 'retired'"/>
                <field name="quantity_total"/>
                <field name="quantity_available"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_club_object_item_form" model="ir.ui.view">
        <field name="name">club.object.item.form</field>
        <field name="model">club.object.item</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="photo" widget="image" class="oe_avatar"
                        options="{'preview_image': 'photo'}"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Item name..."/></h1>
                        <h4 class="text-muted">
                            <field name="code" readonly="1"/>
                        </h4>
                    </div>
                    <group>
                        <group>
                            <field name="category_id"/>
                            <field name="status" widget="badge"
                                decoration-success="status == 'available'"
                                decoration-info="status == 'loaned'"
                                decoration-warning="status == 'maintenance'"
                                decoration-danger="status == 'retired'"/>
                        </group>
                        <group>
                            <field name="quantity_total"/>
                            <field name="quantity_available"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description" placeholder="Item description..."/>
                        </page>
                        <page string="Current Loans" name="loans">
                            <field name="loan_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="affiliate_id"/>
                                    <field name="loan_date"/>
                                    <field name="due_date"/>
                                    <field name="quantity"/>
                                    <field name="status" widget="badge"
                                        decoration-success="status == 'returned'"
                                        decoration-info="status == 'active'"
                                        decoration-warning="status == 'overdue'"
                                        decoration-danger="status == 'lost'"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_club_object_item_search" model="ir.ui.view">
        <field name="name">club.object.item.search</field>
        <field name="model">club.object.item</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="category_id"/>
                <filter name="available" string="Available"
                    domain="[('status','=','available')]"/>
                <filter name="loaned" string="Loaned"
                    domain="[('status','=','loaned')]"/>
                <filter name="maintenance" string="Maintenance"
                    domain="[('status','=','maintenance')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_category" string="Category"
                        context="{'group_by': 'category_id'}"/>
                    <filter name="group_status" string="Status"
                        context="{'group_by': 'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_club_object_item" model="ir.actions.act_window">
        <field name="name">Items</field>
        <field name="res_model">club.object.item</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_club_object_item_search"/>
        <field name="context">{'search_default_available': 1}</field>
        <field name="path">club-object-items</field>
    </record>

</odoo>
