<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view -->
    <record id="view_club_object_category_list" model="ir.ui.view">
        <field name="name">club.object.category.list</field>
        <field name="model">club.object.category</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="max_loan_days"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_club_object_category_form" model="ir.ui.view">
        <field name="name">club.object.category.form</field>
        <field name="model">club.object.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Category name..."/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="max_loan_days"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Items" name="items">
                            <field name="item_ids">
                                <list>
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="status" widget="badge"
                                        decoration-success="status == 'available'"
                                        decoration-info="status == 'loaned'"
                                        decoration-warning="status == 'maintenance'"
                                        decoration-danger="status == 'retired'"/>
                                    <field name="quantity_total"/>
                                    <field name="quantity_available"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_club_object_category" model="ir.actions.act_window">
        <field name="name">Object Categories</field>
        <field name="res_model">club.object.category</field>
        <field name="view_mode">list,form</field>
        <field name="path">club-object-categories</field>
    </record>

</odoo>
