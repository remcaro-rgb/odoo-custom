<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view (editable) -->
    <record id="view_club_employee_type_list" model="ir.ui.view">
        <field name="name">club.employee.type.list</field>
        <field name="model">club.employee.type</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
            </list>
        </field>
    </record>

    <!-- Action -->
    <record id="action_club_employee_type" model="ir.actions.act_window">
        <field name="name">Employee Types</field>
        <field name="res_model">club.employee.type</field>
        <field name="view_mode">list</field>
        <field name="path">club-employee-types</field>
    </record>

</odoo>
