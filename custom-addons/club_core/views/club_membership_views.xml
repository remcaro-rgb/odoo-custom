<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_club_membership_list" model="ir.ui.view">
        <field name="name">club.membership.list</field>
        <field name="model">club.membership</field>
        <field name="arch" type="xml">
            <list>
                <field name="affiliate_id"/>
                <field name="plan_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="status" widget="badge"
                    decoration-success="status == 'active'"
                    decoration-warning="status == 'suspended'"
                    decoration-danger="status in ('expired','cancelled')"/>
                <field name="invoice_count" string="Invoices"/>
            </list>
        </field>
    </record>

    <record id="view_club_membership_form" model="ir.ui.view">
        <field name="name">club.membership.form</field>
        <field name="model">club.membership</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_activate" string="Activate"
                        type="object" class="btn-primary"
                        invisible="status != 'draft'"/>
                    <button name="action_suspend" string="Suspend"
                        type="object"
                        invisible="status != 'active'"/>
                    <button name="action_cancel" string="Cancel"
                        type="object"
                        invisible="status in ('cancelled','expired')"/>
                    <field name="status" widget="statusbar"
                        statusbar_visible="draft,active,suspended,expired,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_invoices" type="object"
                            class="oe_stat_button" icon="fa-file-text-o"
                            invisible="invoice_count == 0">
                            <field name="invoice_count" widget="statinfo" string="Invoices"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="affiliate_id"/>
                            <field name="plan_id"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="end_date" readonly="1"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_club_membership_search" model="ir.ui.view">
        <field name="name">club.membership.search</field>
        <field name="model">club.membership</field>
        <field name="arch" type="xml">
            <search>
                <field name="affiliate_id"/>
                <field name="plan_id"/>
                <filter name="active" string="Active" domain="[('status','=','active')]"/>
                <filter name="suspended" string="Suspended" domain="[('status','=','suspended')]"/>
                <filter name="expiring_soon" string="Expiring (7 days)"
                    domain="[('status','=','active'),('end_date','&lt;=', (context_today() + datetime.timedelta(days=7)).strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Group By">
                    <filter name="group_plan" string="Plan" context="{'group_by': 'plan_id'}"/>
                    <filter name="group_status" string="Status" context="{'group_by': 'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_club_membership" model="ir.actions.act_window">
        <field name="name">Memberships</field>
        <field name="res_model">club.membership</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_club_membership_search"/>
    </record>

</odoo>
