<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view -->
    <record id="view_club_assembly_vote_list" model="ir.ui.view">
        <field name="name">club.assembly.vote.list</field>
        <field name="model">club.assembly.vote</field>
        <field name="arch" type="xml">
            <list>
                <field name="assembly_id"/>
                <field name="topic_id"/>
                <field name="affiliate_id"/>
                <field name="vote" widget="badge"
                    decoration-success="vote == 'for'"
                    decoration-danger="vote == 'against'"
                    decoration-warning="vote == 'abstain'"/>
                <field name="voted_at"/>
                <field name="notes"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_club_assembly_vote_form" model="ir.ui.view">
        <field name="name">club.assembly.vote.form</field>
        <field name="model">club.assembly.vote</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="topic_id"/>
                            <field name="assembly_id"/>
                            <field name="affiliate_id"/>
                        </group>
                        <group>
                            <field name="vote"/>
                            <field name="voted_at"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_club_assembly_vote_search" model="ir.ui.view">
        <field name="name">club.assembly.vote.search</field>
        <field name="model">club.assembly.vote</field>
        <field name="arch" type="xml">
            <search>
                <field name="affiliate_id"/>
                <field name="topic_id"/>
                <field name="assembly_id"/>
                <filter name="filter_for" string="For"
                    domain="[('vote', '=', 'for')]"/>
                <filter name="filter_against" string="Against"
                    domain="[('vote', '=', 'against')]"/>
                <filter name="filter_abstain" string="Abstain"
                    domain="[('vote', '=', 'abstain')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_assembly" string="Assembly"
                        context="{'group_by': 'assembly_id'}"/>
                    <filter name="group_topic" string="Topic"
                        context="{'group_by': 'topic_id'}"/>
                    <filter name="group_vote" string="Vote"
                        context="{'group_by': 'vote'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_club_assembly_vote" model="ir.actions.act_window">
        <field name="name">Votes</field>
        <field name="res_model">club.assembly.vote</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_club_assembly_vote_search"/>
        <field name="path">club-assembly-votes</field>
    </record>

</odoo>
