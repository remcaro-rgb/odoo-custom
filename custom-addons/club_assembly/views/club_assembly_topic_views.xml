<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view -->
    <record id="view_club_assembly_topic_list" model="ir.ui.view">
        <field name="name">club.assembly.topic.list</field>
        <field name="model">club.assembly.topic</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="assembly_id"/>
                <field name="name"/>
                <field name="topic_type"/>
                <field name="status" widget="badge"
                    decoration-success="status in ('approved',)"
                    decoration-danger="status in ('rejected',)"
                    decoration-warning="status in ('voting_open', 'in_discussion')"
                    decoration-info="status == 'pending'"/>
                <field name="votes_for"/>
                <field name="votes_against"/>
                <field name="votes_abstain"/>
                <field name="vote_result"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_club_assembly_topic_form" model="ir.ui.view">
        <field name="name">club.assembly.topic.form</field>
        <field name="model">club.assembly.topic</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_open_discussion" type="object"
                        string="Open Discussion" class="btn-primary"
                        invisible="status != 'pending'"/>
                    <button name="action_open_voting" type="object"
                        string="Open Voting" class="btn-primary"
                        invisible="status != 'in_discussion'"/>
                    <button name="action_close_voting" type="object"
                        string="Close Voting" class="btn-primary"
                        invisible="status != 'voting_open'"/>
                    <button name="action_table" type="object"
                        string="Table" class="btn-secondary"
                        invisible="status in ('approved', 'rejected', 'tabled')"/>
                    <field name="status" widget="statusbar"
                        statusbar_visible="pending,in_discussion,voting_open,approved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="assembly_id"/>
                            <field name="sequence"/>
                            <field name="topic_type"/>
                        </group>
                        <group>
                            <field name="votes_for"/>
                            <field name="votes_against"/>
                            <field name="votes_abstain"/>
                            <field name="vote_result"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1" colspan="2"/>
                    </group>
                    <group string="Resolution">
                        <field name="resolution" nolabel="1" colspan="2"/>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1" colspan="2"/>
                    </group>
                    <group string="Votes">
                        <field name="vote_ids" nolabel="1" colspan="2">
                            <list editable="bottom">
                                <field name="affiliate_id"/>
                                <field name="vote" widget="badge"
                                    decoration-success="vote == 'for'"
                                    decoration-danger="vote == 'against'"
                                    decoration-warning="vote == 'abstain'"/>
                                <field name="voted_at"/>
                                <field name="notes"/>
                            </list>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_club_assembly_topic_search" model="ir.ui.view">
        <field name="name">club.assembly.topic.search</field>
        <field name="model">club.assembly.topic</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="assembly_id"/>
                <filter name="filter_voting" string="Voting Topics"
                    domain="[('topic_type', '=', 'voting')]"/>
                <filter name="filter_approved" string="Approved"
                    domain="[('status', '=', 'approved')]"/>
                <filter name="filter_rejected" string="Rejected"
                    domain="[('status', '=', 'rejected')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_assembly" string="Assembly"
                        context="{'group_by': 'assembly_id'}"/>
                    <filter name="group_type" string="Type"
                        context="{'group_by': 'topic_type'}"/>
                    <filter name="group_status" string="Status"
                        context="{'group_by': 'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_club_assembly_topic" model="ir.actions.act_window">
        <field name="name">Topics</field>
        <field name="res_model">club.assembly.topic</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_club_assembly_topic_search"/>
        <field name="path">club-assembly-topics</field>
    </record>

</odoo>
