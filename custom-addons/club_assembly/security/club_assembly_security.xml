<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ── Security Groups ──────────────────────────────────────── -->

        <record id="group_assembly_staff" model="res.groups">
            <field name="name">Assembly Staff</field>
            <field name="category_id" ref="base.module_category_hidden"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_assembly_president" model="res.groups">
            <field name="name">Assembly President</field>
            <field name="category_id" ref="base.module_category_hidden"/>
            <field name="implied_ids" eval="[(4, ref('club_assembly.group_assembly_staff'))]"/>
        </record>

        <!-- ── Portal Record Rules ──────────────────────────────────── -->

        <!-- Assembly: portal member sees assemblies they belong to -->
        <record id="rule_assembly_portal_member" model="ir.rule">
            <field name="name">Assembly: portal sees own assemblies</field>
            <field name="model_id" ref="model_club_assembly"/>
            <field name="domain_force">[('member_ids.partner_id', 'in', [user.partner_id.id])]</field>
            <field name="groups" eval="[(4, ref('club_core.group_club_member'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Topic: portal member sees topics of their assemblies -->
        <record id="rule_topic_portal_member" model="ir.rule">
            <field name="name">Topic: portal sees topics of own assemblies</field>
            <field name="model_id" ref="model_club_assembly_topic"/>
            <field name="domain_force">[('assembly_id.member_ids.partner_id', 'in', [user.partner_id.id])]</field>
            <field name="groups" eval="[(4, ref('club_core.group_club_member'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Vote: portal member sees own votes -->
        <record id="rule_vote_portal_member" model="ir.rule">
            <field name="name">Vote: portal sees own votes</field>
            <field name="model_id" ref="model_club_assembly_vote"/>
            <field name="domain_force">[('affiliate_id.partner_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('club_core.group_club_member'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Attendance: portal member sees attendance of own assemblies -->
        <record id="rule_attendance_portal_member" model="ir.rule">
            <field name="name">Attendance: portal sees attendance of own assemblies</field>
            <field name="model_id" ref="model_club_assembly_attendance"/>
            <field name="domain_force">[('assembly_id.member_ids.partner_id', 'in', [user.partner_id.id])]</field>
            <field name="groups" eval="[(4, ref('club_core.group_club_member'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

    </data>
</odoo>
