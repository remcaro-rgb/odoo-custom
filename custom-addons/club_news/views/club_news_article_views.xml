<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Kanban view -->
    <record id="view_club_news_article_kanban" model="ir.ui.view">
        <field name="name">club.news.article.kanban</field>
        <field name="model">club.news.article</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="title"/>
                <field name="status"/>
                <field name="is_featured"/>
                <field name="is_pinned"/>
                <field name="category_id"/>
                <field name="cover_image"/>
                <field name="publish_date"/>
                <field name="author_id"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div t-if="record.cover_image.raw_value"
                                 class="o_kanban_image_fill_left d-none d-md-block"
                                 style="width: 96px; min-height: 96px;">
                                <field name="cover_image" widget="image"
                                       options="{'preview_image': 'cover_image'}"/>
                            </div>
                            <div class="oe_kanban_details">
                                <div class="o_kanban_record_top">
                                    <strong class="o_kanban_record_title">
                                        <field name="title"/>
                                    </strong>
                                </div>
                                <span class="text-muted"><field name="name"/></span>
                                <div class="o_kanban_record_bottom mt-1">
                                    <field name="status" widget="badge"
                                        decoration-success="status == 'published'"
                                        decoration-info="status == 'draft'"
                                        decoration-warning="status == 'archived'"/>
                                    <span t-if="record.is_featured.raw_value"
                                          class="badge text-bg-warning ms-1">Featured</span>
                                    <span t-if="record.is_pinned.raw_value"
                                          class="badge text-bg-primary ms-1">Pinned</span>
                                </div>
                                <div class="text-muted small mt-1">
                                    <field name="category_id"/>
                                    <span t-if="record.publish_date.raw_value"
                                          class="float-end">
                                        <field name="publish_date"/>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- List view -->
    <record id="view_club_news_article_list" model="ir.ui.view">
        <field name="name">club.news.article.list</field>
        <field name="model">club.news.article</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="title"/>
                <field name="category_id"/>
                <field name="author_id"/>
                <field name="publish_date"/>
                <field name="target_audience"/>
                <field name="is_featured"/>
                <field name="is_pinned"/>
                <field name="view_count"/>
                <field name="status" widget="badge"
                    decoration-success="status == 'published'"
                    decoration-info="status == 'draft'"
                    decoration-warning="status == 'archived'"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_club_news_article_form" model="ir.ui.view">
        <field name="name">club.news.article.form</field>
        <field name="model">club.news.article</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_publish" type="object"
                        string="Publish" class="btn-primary"
                        invisible="status != 'draft'"/>
                    <button name="action_archive_article" type="object"
                        string="Archive"
                        invisible="status != 'published'"/>
                    <button name="action_draft" type="object"
                        string="Reset to Draft"
                        invisible="status != 'archived'"/>
                    <field name="status" widget="statusbar"
                        statusbar_visible="draft,published,archived"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <field name="cover_image" widget="image" class="oe_avatar"
                        options="{'preview_image': 'cover_image'}"/>
                    <div class="oe_title">
                        <label for="title"/>
                        <h1><field name="title" placeholder="Article Title"/></h1>
                        <h4 class="text-muted">
                            <field name="name" readonly="1"/>
                        </h4>
                    </div>
                    <group>
                        <group>
                            <field name="category_id"/>
                            <field name="author_id"/>
                            <field name="target_audience"/>
                            <field name="tag_ids" widget="many2many_tags"
                                options="{'color_field': 'color'}"/>
                        </group>
                        <group>
                            <field name="publish_date"/>
                            <field name="expiry_date"/>
                            <field name="is_featured"/>
                            <field name="is_pinned"/>
                            <field name="view_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Content" name="content">
                            <field name="summary" placeholder="Short excerpt..."/>
                            <field name="content" placeholder="Article body..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_club_news_article_search" model="ir.ui.view">
        <field name="name">club.news.article.search</field>
        <field name="model">club.news.article</field>
        <field name="arch" type="xml">
            <search>
                <field name="title"/>
                <field name="name"/>
                <field name="category_id"/>
                <field name="tag_ids"/>
                <field name="author_id"/>
                <filter name="published" string="Published"
                    domain="[('status', '=', 'published')]"/>
                <filter name="draft" string="Draft"
                    domain="[('status', '=', 'draft')]"/>
                <filter name="archived" string="Archived"
                    domain="[('status', '=', 'archived')]"/>
                <separator/>
                <filter name="featured" string="Featured"
                    domain="[('is_featured', '=', True)]"/>
                <filter name="pinned" string="Pinned"
                    domain="[('is_pinned', '=', True)]"/>
                <separator/>
                <filter name="date_this_month" string="This Month"
                    domain="[
                        ('publish_date', '&gt;=', (context_today() - relativedelta(day=1)).strftime('%Y-%m-%d')),
                        ('publish_date', '&lt;=', context_today().strftime('%Y-%m-%d')),
                    ]"/>
                <filter name="date_last_month" string="Last Month"
                    domain="[
                        ('publish_date', '&gt;=', (context_today() - relativedelta(months=1, day=1)).strftime('%Y-%m-%d')),
                        ('publish_date', '&lt;', (context_today() - relativedelta(day=1)).strftime('%Y-%m-%d')),
                    ]"/>
                <group expand="0" string="Group By">
                    <filter name="group_category" string="Category"
                        context="{'group_by': 'category_id'}"/>
                    <filter name="group_status" string="Status"
                        context="{'group_by': 'status'}"/>
                    <filter name="group_audience" string="Target Audience"
                        context="{'group_by': 'target_audience'}"/>
                    <filter name="group_author" string="Author"
                        context="{'group_by': 'author_id'}"/>
                    <filter name="group_publish_date" string="Publish Date"
                        context="{'group_by': 'publish_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action: All Articles -->
    <record id="action_club_news_article" model="ir.actions.act_window">
        <field name="name">All Articles</field>
        <field name="res_model">club.news.article</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_club_news_article_search"/>
        <field name="path">club-news-articles</field>
    </record>

    <!-- Action: Published Articles -->
    <record id="action_club_news_article_published" model="ir.actions.act_window">
        <field name="name">Published Articles</field>
        <field name="res_model">club.news.article</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_club_news_article_search"/>
        <field name="domain">[('status', '=', 'published')]</field>
        <field name="path">club-news-published</field>
    </record>

</odoo>
