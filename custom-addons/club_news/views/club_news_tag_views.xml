<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view (editable) -->
    <record id="view_club_news_tag_list" model="ir.ui.view">
        <field name="name">club.news.tag.list</field>
        <field name="model">club.news.tag</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
            </list>
        </field>
    </record>

    <!-- Action -->
    <record id="action_club_news_tag" model="ir.actions.act_window">
        <field name="name">News Tags</field>
        <field name="res_model">club.news.tag</field>
        <field name="view_mode">list</field>
        <field name="path">club-news-tags</field>
    </record>

</odoo>
