<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ── Security Groups ──────────────────────────────────────── -->

        <record id="group_news_staff" model="res.groups">
            <field name="name">News Staff</field>
            <field name="category_id" ref="base.module_category_hidden"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- ── Record Rules ─────────────────────────────────────────── -->

        <!-- Portal members: read published articles with audience all or members_only -->
        <record id="rule_article_portal_published" model="ir.rule">
            <field name="name">News Article: portal sees published (all/members_only)</field>
            <field name="model_id" ref="model_club_news_article"/>
            <field name="domain_force">[
                ('status', '=', 'published'),
                ('target_audience', 'in', ['all', 'members_only']),
            ]</field>
            <field name="groups" eval="[(4, ref('club_core.group_club_member'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Portal members: read categories -->
        <record id="rule_category_portal_read" model="ir.rule">
            <field name="name">News Category: portal reads all</field>
            <field name="model_id" ref="model_club_news_category"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('club_core.group_club_member'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Portal members: read tags -->
        <record id="rule_tag_portal_read" model="ir.rule">
            <field name="name">News Tag: portal reads all</field>
            <field name="model_id" ref="model_club_news_tag"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('club_core.group_club_member'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

    </data>
</odoo>
