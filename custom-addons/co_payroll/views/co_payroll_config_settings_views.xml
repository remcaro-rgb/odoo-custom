<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_form_co_payroll" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.co_payroll</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Colombian Payroll" string="Colombian Payroll" name="co_payroll">
                    <block title="Payroll Constants">
                        <setting>
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="co_payroll_year" class="col-lg-3 o_light_label"/>
                                    <field name="co_payroll_year"/>
                                </div>
                                <div class="row mt16">
                                    <label for="co_payroll_smlmv" class="col-lg-3 o_light_label"/>
                                    <field name="co_payroll_smlmv"/>
                                </div>
                                <div class="row mt16">
                                    <label for="co_payroll_uvt" class="col-lg-3 o_light_label"/>
                                    <field name="co_payroll_uvt"/>
                                </div>
                                <div class="row mt16">
                                    <label for="co_payroll_transport_allowance" class="col-lg-3 o_light_label"/>
                                    <field name="co_payroll_transport_allowance"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

    <record id="action_co_payroll_config_settings" model="ir.actions.act_window">
        <field name="name">Payroll Settings</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{'module': 'co_payroll'}</field>
        <field name="path">co-payroll-settings</field>
    </record>

</odoo>
