<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_co_salary_concept_form" model="ir.ui.view">
        <field name="name">co.salary.concept.form</field>
        <field name="model">co.salary.concept</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="concept_type"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="active"/>
                            <field name="appears_on_payslip"/>
                        </group>
                    </group>
                    <group string="Formula">
                        <field name="formula" nolabel="1" placeholder="e.g., basic_salary * 0.04"/>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_co_salary_concept_list" model="ir.ui.view">
        <field name="name">co.salary.concept.list</field>
        <field name="model">co.salary.concept</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="concept_type" widget="badge"/>
                <field name="formula"/>
                <field name="appears_on_payslip"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_co_salary_concept_search" model="ir.ui.view">
        <field name="name">co.salary.concept.search</field>
        <field name="model">co.salary.concept</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <filter name="earnings" string="Earnings"
                        domain="[('concept_type', '=', 'earning')]"/>
                <filter name="deductions" string="Deductions"
                        domain="[('concept_type', '=', 'deduction')]"/>
                <filter name="employer" string="Employer"
                        domain="[('concept_type', '=', 'employer')]"/>
                <filter name="provisions" string="Provisions"
                        domain="[('concept_type', '=', 'provision')]"/>
                <group>
                    <filter name="group_type" string="Type"
                            context="{'group_by': 'concept_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_co_salary_concept" model="ir.actions.act_window">
        <field name="name">Salary Concepts</field>
        <field name="res_model">co.salary.concept</field>
        <field name="view_mode">list,form</field>
        <field name="path">co-salary-concepts</field>
    </record>

</odoo>
