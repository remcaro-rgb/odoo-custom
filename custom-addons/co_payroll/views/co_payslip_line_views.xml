<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_co_payslip_line_list" model="ir.ui.view">
        <field name="name">co.payslip.line.list</field>
        <field name="model">co.payslip.line</field>
        <field name="arch" type="xml">
            <list>
                <field name="payslip_id"/>
                <field name="employee_id"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="code"/>
                <field name="name"/>
                <field name="line_type" widget="badge"/>
                <field name="amount" sum="Total"/>
            </list>
        </field>
    </record>

    <record id="view_co_payslip_line_search" model="ir.ui.view">
        <field name="name">co.payslip.line.search</field>
        <field name="model">co.payslip.line</field>
        <field name="arch" type="xml">
            <search>
                <field name="employee_id"/>
                <field name="code"/>
                <field name="name"/>
                <field name="line_type"/>
                <group>
                    <filter name="group_employee" string="Employee"
                            context="{'group_by': 'employee_id'}"/>
                    <filter name="group_type" string="Type"
                            context="{'group_by': 'line_type'}"/>
                    <filter name="group_code" string="Code"
                            context="{'group_by': 'code'}"/>
                    <filter name="group_period" string="Period"
                            context="{'group_by': 'date_from:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_co_payslip_line_pivot" model="ir.ui.view">
        <field name="name">co.payslip.line.pivot</field>
        <field name="model">co.payslip.line</field>
        <field name="arch" type="xml">
            <pivot>
                <field name="employee_id" type="row"/>
                <field name="code" type="col"/>
                <field name="amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_co_payslip_line" model="ir.actions.act_window">
        <field name="name">Payslip Lines</field>
        <field name="res_model">co.payslip.line</field>
        <field name="view_mode">list,pivot</field>
        <field name="path">co-payslip-lines</field>
    </record>

</odoo>
