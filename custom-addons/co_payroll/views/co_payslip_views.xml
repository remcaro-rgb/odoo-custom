<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_co_payslip_form" model="ir.ui.view">
        <field name="name">co.payslip.form</field>
        <field name="model">co.payslip</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_compute" string="Compute"
                            type="object" invisible="state != 'draft'"
                            class="oe_highlight"/>
                    <button name="action_confirm" string="Confirm"
                            type="object" invisible="state != 'computed'"
                            class="oe_highlight"
                            groups="co_payroll.group_co_payroll_manager"/>
                    <button name="action_cancel" string="Cancel"
                            type="object" invisible="state in ('done', 'cancelled')"/>
                    <button name="action_reset_draft" string="Reset to Draft"
                            type="object" invisible="state not in ('computed', 'cancelled')"
                            groups="co_payroll.group_co_payroll_manager"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,computed,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_id" readonly="state != 'draft'"/>
                            <field name="contract_id"/>
                            <field name="department_id"/>
                            <field name="pay_frequency" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="date_from" readonly="state != 'draft'"/>
                            <field name="date_to" readonly="state != 'draft'"/>
                            <field name="worked_days" readonly="state != 'draft'"/>
                            <field name="total_days" readonly="state != 'draft'"/>
                            <field name="company_id" invisible="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Earnings">
                            <group>
                                <group>
                                    <field name="basic_salary" widget="monetary"/>
                                    <field name="transport_allowance" widget="monetary"/>
                                    <field name="overtime_amount" widget="monetary"/>
                                </group>
                                <group>
                                    <field name="commissions" widget="monetary"
                                           readonly="state != 'draft'"/>
                                    <field name="bonuses" widget="monetary"
                                           readonly="state != 'draft'"/>
                                    <field name="other_earnings" widget="monetary"
                                           readonly="state != 'draft'"/>
                                </group>
                            </group>
                            <group>
                                <field name="total_earnings" widget="monetary"
                                       class="oe_subtotal_footer_separator"/>
                                <field name="ibc" widget="monetary"/>
                            </group>
                        </page>
                        <page string="Deductions">
                            <group>
                                <group string="Social Security">
                                    <field name="eps_employee" widget="monetary"/>
                                    <field name="afp_employee" widget="monetary"/>
                                    <field name="solidarity_fund" widget="monetary"/>
                                </group>
                                <group string="Other Deductions">
                                    <field name="withholding_tax" widget="monetary"/>
                                    <field name="manual_deductions" widget="monetary"/>
                                    <field name="loan_deductions" widget="monetary"/>
                                </group>
                            </group>
                            <group>
                                <field name="total_deductions" widget="monetary"
                                       class="oe_subtotal_footer_separator"/>
                            </group>
                        </page>
                        <page string="Employer Contributions">
                            <group>
                                <group>
                                    <field name="eps_employer" widget="monetary"/>
                                    <field name="afp_employer" widget="monetary"/>
                                    <field name="arl_employer" widget="monetary"/>
                                </group>
                                <group>
                                    <field name="caja_compensacion" widget="monetary"/>
                                    <field name="icbf" widget="monetary"/>
                                    <field name="sena" widget="monetary"/>
                                </group>
                            </group>
                            <group>
                                <field name="total_employer" widget="monetary"
                                       class="oe_subtotal_footer_separator"/>
                            </group>
                        </page>
                        <page string="Provisions">
                            <group>
                                <group>
                                    <field name="prima_provision" widget="monetary"/>
                                    <field name="cesantias_provision" widget="monetary"/>
                                </group>
                                <group>
                                    <field name="intereses_cesantias_provision" widget="monetary"/>
                                    <field name="vacaciones_provision" widget="monetary"/>
                                </group>
                            </group>
                            <group>
                                <field name="total_provisions" widget="monetary"
                                       class="oe_subtotal_footer_separator"/>
                            </group>
                        </page>
                        <page string="Detail Lines">
                            <field name="line_ids" readonly="1">
                                <list>
                                    <field name="sequence" widget="handle"/>
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="line_type" widget="badge"/>
                                    <field name="amount" sum="Total"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                    <group class="oe_subtotal_footer">
                        <field name="net_pay" widget="monetary"
                               class="oe_subtotal_footer_separator"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_co_payslip_list" model="ir.ui.view">
        <field name="name">co.payslip.list</field>
        <field name="model">co.payslip</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="total_earnings" sum="Total Earnings"/>
                <field name="total_deductions" sum="Total Deductions"/>
                <field name="net_pay" sum="Net Pay"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'computed'"
                       decoration-success="state == 'done'"
                       decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <record id="view_co_payslip_search" model="ir.ui.view">
        <field name="name">co.payslip.search</field>
        <field name="model">co.payslip</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <filter name="draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="computed" string="Computed" domain="[('state', '=', 'computed')]"/>
                <filter name="done" string="Done" domain="[('state', '=', 'done')]"/>
                <separator/>
                <filter name="current_month" string="Current Month"
                        domain="[('date_from', '&gt;=', (context_today() - relativedelta(day=1)).strftime('%%Y-%%m-%%d')),
                                 ('date_from', '&lt;=', (context_today() + relativedelta(day=31)).strftime('%%Y-%%m-%%d'))]"/>
                <group>
                    <filter name="group_employee" string="Employee"
                            context="{'group_by': 'employee_id'}"/>
                    <filter name="group_department" string="Department"
                            context="{'group_by': 'department_id'}"/>
                    <filter name="group_state" string="Status"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_period" string="Period"
                            context="{'group_by': 'date_from:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_co_payslip" model="ir.actions.act_window">
        <field name="name">Payslips</field>
        <field name="res_model">co.payslip</field>
        <field name="view_mode">list,form</field>
        <field name="path">co-payslips</field>
        <field name="context">{'search_default_current_month': 1}</field>
    </record>

</odoo>
