#. module: club_pos
#: model:ir.model.fields,field_description:club_pos.field_pos_payment_method__is_cargo_socio
msgid "Cargo a Socio"
msgstr "Cargo a Socio"

#. module: club_pos
#: model:ir.model.fields,help:club_pos.field_pos_payment_method__is_cargo_socio
msgid "If enabled, this payment method charges the affiliate member account. Only usable when the customer is a club affiliate with active membership."
msgstr "Si se activa, este metodo de pago genera un cargo a la cuenta del socio. Solo utilizable cuando el cliente es un socio del club con membresia activa."

#. module: club_pos
#: model:ir.model.fields,field_description:club_pos.field_pos_payment_method__cargo_socio_account_id
msgid "Affiliate Payable Account"
msgstr "Cuenta por Cobrar a Socios"

#. module: club_pos
#: model:ir.model.fields,help:club_pos.field_pos_payment_method__cargo_socio_account_id
msgid "Account used for \"Cargo a Socio\" entries (e.g. Cuentas por Cobrar a Socios). Debit this account when charging to affiliate."
msgstr "Cuenta utilizada para los asientos de \"Cargo a Socio\" (ej. Cuentas por Cobrar a Socios). Se debita esta cuenta al cargar al socio."

#. module: club_pos
#: model:ir.model.fields,field_description:club_pos.field_pos_payment__cargo_socio_signature
#: model:ir.model.fields,field_description:club_pos.field_pos_order__cargo_socio_signature
