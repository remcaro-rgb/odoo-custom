#, python-format
msgid "Cargo a Socio requires a customer. Please select an affiliate."
msgstr "Cargo a Socio requiere un cliente. Por favor seleccione un socio."

#. module: club_pos
#: code:addons/club_pos/models/pos_order.py:0
#, python-format
