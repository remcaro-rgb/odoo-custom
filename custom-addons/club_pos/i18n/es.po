msgstr "Verdadero si algun pago utiliza el metodo Cargo a Socio."

#. module: club_pos
#: model:ir.model.fields,field_description:club_pos.field_res_partner__is_club_affiliate
msgid "True if this partner is linked to an active club affiliate."
msgstr "Verdadero si este contacto esta vinculado a un socio activo del club."

#. module: club_pos
#: model_terms:ir.ui.view,arch_db:club_pos.view_pos_pos_form_inherit_club
