<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ── Module category ─────────────────────────────────────────── -->
        <record id="module_category_fixed_assets" model="ir.module.category">
            <field name="name">Fixed Assets</field>
            <field name="sequence">20</field>
        </record>

        <!-- ── Security Groups ─────────────────────────────────────────── -->
        <record id="group_fixed_asset_user" model="res.groups">
            <field name="name">User</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_fixed_asset_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="implied_ids" eval="[(4, ref('group_fixed_asset_user'))]"/>
        </record>

        <!-- ── Record Rules ────────────────────────────────────────────── -->
        <record id="rule_fixed_asset_company" model="ir.rule">
            <field name="name">Fixed Asset: multi-company</field>
            <field name="model_id" ref="model_co_fixed_asset"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

    </data>
</odoo>
