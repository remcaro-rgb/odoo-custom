<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Maintenance: Search View ────────────────────────────────────── -->
    <record id="co_fixed_asset_maintenance_view_search" model="ir.ui.view">
        <field name="name">co.fixed.asset.maintenance.search</field>
        <field name="model">co.fixed.asset.maintenance</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="asset_id"/>
                <separator/>
                <filter string="Preventive" name="preventive" domain="[('maintenance_type', '=', 'preventive')]"/>
                <filter string="Corrective" name="corrective" domain="[('maintenance_type', '=', 'corrective')]"/>
                <separator/>
                <group>
                    <filter string="Asset" name="group_asset" context="{'group_by': 'asset_id'}"/>
                    <filter string="Type" name="group_type" context="{'group_by': 'maintenance_type'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ── Maintenance: List View ──────────────────────────────────────── -->
    <record id="co_fixed_asset_maintenance_view_list" model="ir.ui.view">
        <field name="name">co.fixed.asset.maintenance.list</field>
        <field name="model">co.fixed.asset.maintenance</field>
        <field name="arch" type="xml">
            <list>
                <field name="date"/>
                <field name="asset_id"/>
                <field name="name"/>
                <field name="maintenance_type" widget="badge"/>
                <field name="cost" sum="Total Cost"/>
                <field name="responsible_id"/>
                <field name="next_date"/>
            </list>
        </field>
    </record>

    <!-- ── Maintenance: Form View ──────────────────────────────────────── -->
    <record id="co_fixed_asset_maintenance_view_form" model="ir.ui.view">
        <field name="name">co.fixed.asset.maintenance.form</field>
        <field name="model">co.fixed.asset.maintenance</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="asset_id"/>
                            <field name="name"/>
                            <field name="maintenance_type"/>
                            <field name="date"/>
                            <field name="next_date"/>
                        </group>
                        <group>
                            <field name="currency_id" invisible="1"/>
                            <field name="cost"/>
                            <field name="responsible_id"/>
                        </group>
                    </group>
                    <separator string="Notes"/>
                    <field name="note"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ── Maintenance: Action ─────────────────────────────────────────── -->
    <record id="co_fixed_asset_maintenance_action" model="ir.actions.act_window">
        <field name="name">Maintenance</field>
        <field name="res_model">co.fixed.asset.maintenance</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="co_fixed_asset_maintenance_view_search"/>
        <field name="path">fixed-asset-maintenance</field>
    </record>

</odoo>
