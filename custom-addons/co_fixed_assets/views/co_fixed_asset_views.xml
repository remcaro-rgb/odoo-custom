<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Asset: Search View ──────────────────────────────────────────── -->
    <record id="co_fixed_asset_view_search" model="ir.ui.view">
        <field name="name">co.fixed.asset.search</field>
        <field name="model">co.fixed.asset</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="serial_number"/>
                <field name="category_id"/>
                <field name="responsible_id"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Running" name="running" domain="[('state', '=', 'running')]"/>
                <filter string="Closed" name="close" domain="[('state', '=', 'close')]"/>
                <filter string="Disposed" name="disposed" domain="[('state', '=', 'disposed')]"/>
                <separator/>
                <filter string="Active" name="active" domain="[('state', 'in', ['draft', 'running'])]"/>
                <separator/>
                <group>
                    <filter string="Category" name="group_category" context="{'group_by': 'category_id'}"/>
                    <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Responsible" name="group_responsible" context="{'group_by': 'responsible_id'}"/>
                    <filter string="Purchase Date" name="group_purchase_date" context="{'group_by': 'purchase_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ── Asset: List View ────────────────────────────────────────────── -->
    <record id="co_fixed_asset_view_list" model="ir.ui.view">
        <field name="name">co.fixed.asset.list</field>
        <field name="model">co.fixed.asset</field>
        <field name="arch" type="xml">
            <list decoration-muted="state == 'disposed'" decoration-info="state == 'draft'" decoration-success="state == 'running'">
                <field name="code"/>
                <field name="name"/>
                <field name="category_id"/>
                <field name="purchase_date"/>
                <field name="purchase_value" sum="Total Purchase"/>
                <field name="accumulated_depreciation" sum="Total Depreciation"/>
                <field name="book_value" sum="Total Book Value"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'running'"
                       decoration-warning="state == 'close'"
                       decoration-danger="state == 'disposed'"/>
            </list>
        </field>
    </record>

    <!-- ── Asset: Form View ────────────────────────────────────────────── -->
    <record id="co_fixed_asset_view_form" model="ir.ui.view">
        <field name="name">co.fixed.asset.form</field>
        <field name="model">co.fixed.asset</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" type="object" string="Confirm"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_post_depreciation" type="object"
                            string="Post Depreciation"
                            class="btn-primary"
                            invisible="state != 'running'"/>
                    <button name="action_close" type="object" string="Close"
                            invisible="state != 'running'"/>
                    <button name="action_dispose" type="object" string="Dispose"
                            class="btn-danger"
                            invisible="state not in ('running', 'close')"
                            confirm="Are you sure you want to dispose this asset? This will create a reversal journal entry."/>
                    <button name="action_set_to_draft" type="object"
                            string="Reset to Draft"
                            invisible="state not in ('running', 'close')"
                            groups="co_fixed_assets.group_fixed_asset_manager"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,running,close"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_depreciations" type="object"
                                class="oe_stat_button" icon="fa-bar-chart">
                            <field name="depreciation_count" widget="statinfo" string="Depreciations"/>
                        </button>
                        <button name="action_view_maintenance" type="object"
                                class="oe_stat_button" icon="fa-wrench">
                            <field name="maintenance_count" widget="statinfo" string="Maintenance"/>
                        </button>
                        <button name="action_view_moves" type="object"
                                class="oe_stat_button" icon="fa-book">
                            <field name="move_count" widget="statinfo" string="Entries"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Asset Name"/>
                        </h1>
                        <h3>
                            <field name="code" readonly="1"/>
                        </h3>
                    </div>
                    <group>
                        <group>
                            <field name="category_id"/>
                            <field name="serial_number"/>
                            <field name="purchase_date"/>
                            <field name="responsible_id"/>
                            <field name="location"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="purchase_value"/>
                            <field name="salvage_value"/>
                            <field name="depreciable_value"/>
                            <field name="accumulated_depreciation"/>
                            <field name="book_value"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Depreciation" name="depreciation">
                            <group>
                                <group>
                                    <field name="depreciation_method"/>
                                    <field name="useful_life"/>
                                    <field name="degressive_factor"
                                           invisible="depreciation_method != 'degressive'"/>
                                </group>
                            </group>
                            <field name="depreciation_line_ids" readonly="1">
                                <list decoration-success="move_id" decoration-muted="not move_id">
                                    <field name="sequence" string="#"/>
                                    <field name="date"/>
                                    <field name="amount" sum="Total"/>
                                    <field name="cumulative_amount"/>
                                    <field name="remaining_value"/>
                                    <field name="move_id" optional="show"/>
                                </list>
                            </field>
                        </page>
                        <page string="Accounting" name="accounting">
                            <group>
                                <group>
                                    <field name="journal_id"/>
                                    <field name="asset_account_id"/>
                                </group>
                                <group>
                                    <field name="depreciation_account_id"/>
                                    <field name="expense_account_id"/>
                                </group>
                            </group>
                        </page>
                        <page string="Maintenance" name="maintenance">
                            <field name="maintenance_ids">
                                <list editable="bottom">
                                    <field name="date"/>
                                    <field name="name"/>
                                    <field name="maintenance_type"/>
                                    <field name="cost" sum="Total Cost"/>
                                    <field name="responsible_id"/>
                                    <field name="next_date"/>
                                    <field name="note" optional="hide"/>
                                </list>
                            </field>
                        </page>
                        <page string="Disposal" name="disposal"
                              invisible="state != 'disposed'">
                            <group>
                                <group>
                                    <field name="disposal_date"/>
                                    <field name="disposal_move_id"/>
                                </group>
                            </group>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="note" placeholder="Internal notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ── Asset: Action ───────────────────────────────────────────────── -->
    <record id="co_fixed_asset_action" model="ir.actions.act_window">
        <field name="name">Fixed Assets</field>
        <field name="res_model">co.fixed.asset</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="co_fixed_asset_view_search"/>
        <field name="path">fixed-assets</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register your first fixed asset
            </p>
            <p>
                Track fixed assets, generate depreciation schedules, and manage disposals.
            </p>
        </field>
    </record>

</odoo>
