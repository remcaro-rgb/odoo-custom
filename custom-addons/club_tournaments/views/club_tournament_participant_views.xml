<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view -->
    <record id="view_club_tournament_participant_list" model="ir.ui.view">
        <field name="name">club.tournament.participant.list</field>
        <field name="model">club.tournament.participant</field>
        <field name="arch" type="xml">
            <list>
                <field name="tournament_id"/>
                <field name="affiliate_id"/>
                <field name="registration_date"/>
                <field name="seed"/>
                <field name="status" widget="badge"
                    decoration-info="status == 'registered'"
                    decoration-success="status in ('active', 'winner')"
                    decoration-danger="status == 'eliminated'"
                    decoration-muted="status == 'withdrawn'"/>
                <field name="final_position"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_club_tournament_participant_form" model="ir.ui.view">
        <field name="name">club.tournament.participant.form</field>
        <field name="model">club.tournament.participant</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="tournament_id"/>
                            <field name="affiliate_id"/>
                            <field name="registration_date"/>
                        </group>
                        <group>
                            <field name="seed"/>
                            <field name="status"/>
                            <field name="final_position"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_club_tournament_participant_search" model="ir.ui.view">
        <field name="name">club.tournament.participant.search</field>
        <field name="model">club.tournament.participant</field>
        <field name="arch" type="xml">
            <search>
                <field name="affiliate_id"/>
                <field name="tournament_id"/>
                <filter name="filter_registered" string="Registered"
                    domain="[('status', '=', 'registered')]"/>
                <filter name="filter_active" string="Active"
                    domain="[('status', '=', 'active')]"/>
                <filter name="filter_winners" string="Winners"
                    domain="[('status', '=', 'winner')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_tournament" string="Tournament"
                        context="{'group_by': 'tournament_id'}"/>
                    <filter name="group_status" string="Status"
                        context="{'group_by': 'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_club_tournament_participant" model="ir.actions.act_window">
        <field name="name">Participants</field>
        <field name="res_model">club.tournament.participant</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_club_tournament_participant_search"/>
        <field name="path">club-tournament-participants</field>
    </record>

</odoo>
