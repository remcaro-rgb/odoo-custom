<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ── Security Groups ──────────────────────────────────────── -->

        <record id="group_tournament_staff" model="res.groups">
            <field name="name">Tournament Staff</field>
            <field name="category_id" ref="base.module_category_hidden"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- ── Record Rules ─────────────────────────────────────────── -->

        <!-- Portal: affiliate sees tournaments they participate in -->
        <record id="rule_tournament_portal" model="ir.rule">
            <field name="name">Tournament: portal sees own tournaments</field>
            <field name="model_id" ref="model_club_tournament"/>
            <field name="domain_force">[('participant_ids.affiliate_id.partner_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('club_core.group_club_member'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Portal: affiliate sees only own participations -->
        <record id="rule_participant_portal" model="ir.rule">
            <field name="name">Participant: portal sees own participations</field>
            <field name="model_id" ref="model_club_tournament_participant"/>
            <field name="domain_force">[('affiliate_id.partner_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('club_core.group_club_member'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

    </data>
</odoo>
