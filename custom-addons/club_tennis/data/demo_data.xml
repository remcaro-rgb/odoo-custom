        </record>

        <!-- ── Courts ──────────────────────────────────────────────── -->

        <record id="court_clay_01" model="club.tennis.court">
            <field name="name">Court 1 - Clay</field>
            <field name="surface">clay</field>
            <field name="indoor" eval="False"/>
            <field name="under_maintenance" eval="False"/>
        </record>

        <record id="court_hard_02" model="club.tennis.court">
            <field name="name">Court 2 - Hard Indoor</field>
            <field name="surface">hard</field>
            <field name="indoor" eval="True"/>
            <field name="under_maintenance" eval="False"/>
        </record>

        <record id="court_grass_03" model="club.tennis.court">
            <field name="name">Court 3 - Grass</field>
            <field name="surface">grass</field>
