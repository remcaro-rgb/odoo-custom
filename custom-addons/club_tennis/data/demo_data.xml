        <!-- ── Affiliates ─────────────────────────────────────────── -->

        <record id="affiliate_tennis_01" model="club.affiliate">
            <field name="partner_id" ref="partner_tennis_01"/>
            <field name="membership_type">individual</field>
        </record>

        <record id="affiliate_tennis_02" model="club.affiliate">
            <field name="partner_id" ref="partner_tennis_02"/>
            <field name="membership_type">individual</field>
        </record>

        <record id="affiliate_tennis_03" model="club.affiliate">
