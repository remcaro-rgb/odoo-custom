        <record id="booking_01" model="club.tennis.booking">
            <field name="court_id" ref="court_clay_01"/>
            <field name="affiliate_ids" eval="[(6, 0, [ref('affiliate_tennis_01'), ref('affiliate_tennis_02')])]"/>
