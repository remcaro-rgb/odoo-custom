<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view -->
    <record id="view_club_tennis_match_list" model="ir.ui.view">
        <field name="name">club.tennis.match.list</field>
        <field name="model">club.tennis.match</field>
        <field name="arch" type="xml">
            <list>
                <field name="booking_id"/>
                <field name="player_ids" widget="many2many_tags"/>
                <field name="set_1_score"/>
                <field name="set_2_score"/>
                <field name="set_3_score"/>
                <field name="winner_id"/>
                <field name="ranking_points_awarded"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_club_tennis_match_form" model="ir.ui.view">
        <field name="name">club.tennis.match.form</field>
        <field name="model">club.tennis.match</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="booking_id"/>
                            <field name="winner_id"/>
                            <field name="ranking_points_awarded"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Players" name="players">
                            <field name="player_ids" widget="many2many_tags"/>
                        </page>
                        <page string="Scores" name="scores">
                            <group>
                                <field name="set_1_score"/>
                                <field name="set_2_score"/>
                                <field name="set_3_score"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_club_tennis_match_search" model="ir.ui.view">
        <field name="name">club.tennis.match.search</field>
        <field name="model">club.tennis.match</field>
        <field name="arch" type="xml">
            <search>
                <field name="booking_id"/>
                <field name="winner_id"/>
                <field name="player_ids"/>
                <group expand="0" string="Group By">
                    <filter name="group_winner" string="Winner"
                        context="{'group_by': 'winner_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_club_tennis_match" model="ir.actions.act_window">
        <field name="name">Tennis Matches</field>
        <field name="res_model">club.tennis.match</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_club_tennis_match_search"/>
        <field name="path">club-tennis-matches</field>
    </record>

</odoo>
