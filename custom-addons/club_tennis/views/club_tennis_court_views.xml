<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view -->
    <record id="view_club_tennis_court_list" model="ir.ui.view">
        <field name="name">club.tennis.court.list</field>
        <field name="model">club.tennis.court</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="surface"/>
                <field name="indoor"/>
                <field name="under_maintenance" widget="badge"
                    decoration-danger="under_maintenance == True"
                    decoration-success="under_maintenance == False"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_club_tennis_court_form" model="ir.ui.view">
        <field name="name">club.tennis.court.form</field>
        <field name="model">club.tennis.court</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="surface"/>
                            <field name="indoor"/>
                        </group>
                        <group>
                            <field name="under_maintenance"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Bookings" name="bookings">
                            <field name="booking_ids">
                                <list>
                                    <field name="date"/>
                                    <field name="time_slot" widget="float_time"/>
                                    <field name="duration"/>
                                    <field name="status" widget="badge"
                                        decoration-info="status == 'booked'"
                                        decoration-success="status == 'completed'"
                                        decoration-danger="status == 'cancelled'"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_club_tennis_court_search" model="ir.ui.view">
        <field name="name">club.tennis.court.search</field>
        <field name="model">club.tennis.court</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <filter name="available" string="Available"
                    domain="[('under_maintenance','=',False)]"/>
                <filter name="maintenance" string="Under Maintenance"
                    domain="[('under_maintenance','=',True)]"/>
                <filter name="indoor" string="Indoor"
                    domain="[('indoor','=',True)]"/>
                <group expand="0" string="Group By">
                    <filter name="group_surface" string="Surface"
                        context="{'group_by': 'surface'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_club_tennis_court" model="ir.actions.act_window">
        <field name="name">Tennis Courts</field>
        <field name="res_model">club.tennis.court</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_club_tennis_court_search"/>
        <field name="context">{'search_default_available': 1}</field>
        <field name="path">club-tennis-courts</field>
    </record>

</odoo>
