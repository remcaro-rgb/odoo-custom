<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ── Security Groups ──────────────────────────────────────── -->

        <record id="group_tennis_staff" model="res.groups">
            <field name="name">Tennis Staff</field>
            <field name="category_id" ref="base.module_category_hidden"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- ── Portal Record Rules ──────────────────────────────────── -->

        <!-- Booking: portal member sees only bookings where they are a player -->
        <record id="rule_tennis_booking_portal" model="ir.rule">
            <field name="name">Tennis Booking: portal sees own bookings</field>
            <field name="model_id" ref="model_club_tennis_booking"/>
            <field name="domain_force">[('affiliate_ids.partner_id', 'in', [user.partner_id.id])]</field>
            <field name="groups" eval="[(4, ref('club_core.group_club_member'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

    </data>
</odoo>
