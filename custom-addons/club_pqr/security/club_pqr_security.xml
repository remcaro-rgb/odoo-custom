<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ── Security Groups ────────────────────────────────────── -->

        <record id="group_pqr_staff" model="res.groups">
            <field name="name">PQR Staff</field>
            <field name="category_id" ref="base.module_category_hidden"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- ── Record Rules ───────────────────────────────────────── -->

        <!-- Portal / Member: sees only their own PQR requests -->
        <record id="rule_pqr_request_portal_own" model="ir.rule">
            <field name="name">PQR Request: portal sees own requests</field>
            <field name="model_id" ref="model_club_pqr_request"/>
            <field name="domain_force">[('affiliate_id.partner_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('club_core.group_club_member'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Portal / Member: category read-only -->
        <record id="rule_pqr_category_portal" model="ir.rule">
            <field name="name">PQR Category: portal read-only</field>
            <field name="model_id" ref="model_club_pqr_category"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('club_core.group_club_member'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

    </data>
</odoo>
