<odoo>
    <!-- Category for Electronic Invoicing -->
    <record id="module_l10n_co_edi_jorels_category" model="ir.module.category">
        <field name="name">Electronic invoicing</field>
    </record>

    <!-- Privilege for Electronic Invoicing -->
    <record id="privilege_l10n_co_edi_jorels" model="res.groups.privilege">
        <field name="name">Electronic invoicing</field>
        <field name="category_id" ref="module_l10n_co_edi_jorels_category"/>
    </record>

    <!-- Freight Route User Group -->
    <record id="l10n_co_edi_jorels_group_user" model="res.groups">
        <field name="name">User</field>
        <field name="privilege_id" ref="privilege_l10n_co_edi_jorels"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Freight Route Manager Group -->
    <record id="l10n_co_edi_jorels_group_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="privilege_l10n_co_edi_jorels"/>
        <field name="implied_ids" eval="[(4, ref('l10n_co_edi_jorels_group_user'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

    <!-- Invoicing period -->
    <record id="group_invoice_period_enable" model="res.groups">
        <field name="name">Enable invoicing period</field>
        <field name="user_ids" eval="[(4, ref('base.user_root'))]"/>
    </record>

    <!-- Mandate field -->
    <record id="group_invoice_mandate_enable" model="res.groups">
        <field name="name">Enable invoicing mandate</field>
        <field name="user_ids" eval="[(4, ref('base.user_root'))]"/>
    </record>

    <record id="radian_comp_rule" model="ir.rule">
        <field name="name">Radian multi-company</field>
        <field name="model_id" ref="model_l10n_co_edi_jorels_radian"/>
        <field name="global" eval="True"/>
        <field name="domain_force">['|',('company_id','=',False),('company_id', 'in', company_ids)]</field>
    </record>

</odoo>
